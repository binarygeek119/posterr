<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Posterr</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico"/>
  <style>
    html, body {
      margin: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000;
    }
    .hub {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      background: #000;
    }
    .hub-frame {
      position: absolute;
      inset: 0;
      width: 100vw;
      height: 100vh;
      border: 0;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 240ms ease;
      z-index: 1;
      background: #000;
    }
    .hub-frame.is-active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      z-index: 3;
    }
  </style>
</head>
<body>
  <main class="hub" aria-live="polite">
    <iframe id="hubPostersFrame" class="hub-frame is-active" title="Posters" loading="eager"></iframe>
    <iframe id="hubNowShowingFrame" class="hub-frame" title="Now Showing" loading="eager"></iframe>
    <iframe id="hubAdsFrame" class="hub-frame" title="Ads" loading="eager"></iframe>
  </main>
  <script>
    (function () {
      var baseUrl = <%- JSON.stringify(baseUrl) %>;
      var nsCycleEnabled = <%- JSON.stringify(String(typeof nowShowingPageCycleEnabled !== "undefined" ? nowShowingPageCycleEnabled : "false")) %> === "true";
      var viewHotkeysEnabled = <%- JSON.stringify(String(typeof viewHotkeysEnabled !== "undefined" ? viewHotkeysEnabled : "true")) %> === "true";
      var nsCycleEveryMins = parseInt(<%- JSON.stringify(String(typeof nowShowingPageCycleEveryMins !== "undefined" ? nowShowingPageCycleEveryMins : "30")) %>, 10);
      var nsCycleStayMins = parseInt(<%- JSON.stringify(String(typeof nowShowingPageCycleStayMins !== "undefined" ? nowShowingPageCycleStayMins : "5")) %>, 10);
      var defaultDedicated = <%- JSON.stringify(String(typeof homePageCycleDedicatedView !== "undefined" ? homePageCycleDedicatedView : "now-showing")) %>;
      var HOME_CYCLE_EMBED_MSG = "posterr-home-cycle-embed-close";
      var VIEW_SWITCH_MSG = "posterr-view-switch";

      var postersFrame = document.getElementById("hubPostersFrame");
      var nowShowingFrame = document.getElementById("hubNowShowingFrame");
      var adsFrame = document.getElementById("hubAdsFrame");
      var activeView = "posters";
      var cycleTimer = null;

      function ensureSrc(frame, url) {
        if (!frame) return;
        if (frame.getAttribute("src") !== url) frame.setAttribute("src", url);
      }

      function frameByView(view) {
        if (view === "now-showing") return nowShowingFrame;
        if (view === "ads") return adsFrame;
        return postersFrame;
      }

      function activateView(view) {
        activeView = view === "now-showing" || view === "ads" ? view : "posters";
        if (activeView === "now-showing") {
          ensureSrc(nowShowingFrame, nowShowingUrl);
        } else if (activeView === "ads") {
          ensureSrc(adsFrame, adsUrl);
        } else {
          /* Posters-only startup: unload dedicated views so nothing from /ads or /now-showing runs in the background. */
          if (nowShowingFrame) nowShowingFrame.setAttribute("src", "about:blank");
          if (adsFrame) adsFrame.setAttribute("src", "about:blank");
        }
        postersFrame.classList.toggle("is-active", activeView === "posters");
        nowShowingFrame.classList.toggle("is-active", activeView === "now-showing");
        adsFrame.classList.toggle("is-active", activeView === "ads");
      }

      function clearCycleTimer() {
        if (cycleTimer) {
          clearTimeout(cycleTimer);
          cycleTimer = null;
        }
      }

      function scheduleCycleOpen() {
        clearCycleTimer();
        if (!nsCycleEnabled || !Number.isFinite(nsCycleEveryMins) || nsCycleEveryMins <= 0) return;
        cycleTimer = setTimeout(function () {
          activateView(defaultDedicated === "ads" ? "ads" : "now-showing");
          cycleTimer = null;
        }, nsCycleEveryMins * 60 * 1000);
      }

      function switchFromHotkey(k) {
        if (k === "1") {
          activateView("posters");
          scheduleCycleOpen();
        } else if (k === "2") {
          activateView("ads");
          clearCycleTimer();
        } else if (k === "3") {
          activateView("now-showing");
          clearCycleTimer();
        }
      }

      function inFormField(el) {
        if (!el || !el.tagName) return false;
        var t = el.tagName.toLowerCase();
        if (t === "input" || t === "textarea" || t === "select") return true;
        return !!el.isContentEditable;
      }

      var postersUrl = baseUrl + "/posters?hubEmbed=1";
      var nowShowingUrl = baseUrl + "/now-showing?cycleEmbed=1";
      var adsUrl = baseUrl + "/ads?cycleEmbed=1&cycleStayMins=" + encodeURIComponent(String(Number.isFinite(nsCycleStayMins) && nsCycleStayMins > 0 ? nsCycleStayMins : 5));
      ensureSrc(postersFrame, postersUrl);
      if (nowShowingFrame) nowShowingFrame.setAttribute("src", "about:blank");
      if (adsFrame) adsFrame.setAttribute("src", "about:blank");
      activateView("posters");
      scheduleCycleOpen();

      window.addEventListener("message", function (ev) {
        if (ev.origin !== window.location.origin) return;
        var d = ev.data || {};
        if (d.type === HOME_CYCLE_EMBED_MSG) {
          activateView("posters");
          scheduleCycleOpen();
          return;
        }
        if (d.type === VIEW_SWITCH_MSG && d.view) {
          if (d.view === "posters") {
            activateView("posters");
            scheduleCycleOpen();
          } else if (d.view === "now-showing") {
            activateView("now-showing");
            clearCycleTimer();
          } else if (d.view === "ads") {
            activateView("ads");
            clearCycleTimer();
          }
        }
      });

      document.addEventListener("keydown", function (ev) {
        if (!viewHotkeysEnabled) return;
        if (ev.defaultPrevented || ev.ctrlKey || ev.metaKey || ev.altKey) return;
        if (inFormField(ev.target)) return;
        if (ev.key !== "1" && ev.key !== "2" && ev.key !== "3") return;
        ev.preventDefault();
        switchFromHotkey(ev.key);
      }, true);
    })();
  </script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js" crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/font-awesome.min.css">
  <title>Posterr — Now Showing Settings</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
</head>
<body>
  <%if(!user.valid){%><script language='javascript'>window.location.href = '<%=baseUrl%>/logon';</script><%}%>
  <%- include('new-features-banner.ejs') %>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">Posterr</a></li>
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/settings">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Now Showing</li>
      </ol>
    </nav>
    <div class="row gutters-sm">
      <div class="col-md-4 d-none d-md-block">
        <div class="card"><div class="card-body">
          <nav class="nav flex-column nav-pills nav-gap-y-1">
            <a href="<%=baseUrl%>/settings" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-cog"></i><span class="menu">Settings</span></a>
            <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-sync"></i><span class="menu">Sync</span></a>
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-item nav-link has-icon nav-link-faded active"><i class="fal fa-film"></i><span class="menu">Now Showing</span></a>
            <a href="<%=baseUrl%>/settings/ads" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-bullhorn"></i><span class="menu">Ads</span></a>
            <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-key"></i><span class="menu">TMDB API</span></a>
            <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-database"></i><span class="menu">Cache</span></a>
            <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-debug"></i><span class="menu">Debug</span></a>
            <a href="<%=baseUrl%>/settings#about" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-person-sign"></i><span class="menu">About</span></a>
          </nav>
        </div></div>
      </div>
      <div class="col-md-8">
        <div class="card">
          <div class="d-none d-md-flex border-bottom py-2 px-3 justify-content-end align-items-center flex-wrap">
            <a href="<%=baseUrl%>/settings#collapseFive" class="nav-link has-icon text-body py-1 mr-3"><i class="fal fa-play"></i><span class="menu">Now Playing</span></a>
            <a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon text-body py-1"><i class="fal fa-bullhorn"></i><span class="menu">ADS settings</span></a>
          </div>
          <div class="card-header border-bottom mb-3 d-flex d-md-none">
            <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
              <li class="nav-item"><a href="<%=baseUrl%>/settings" class="nav-link has-icon"><i class="fal fa-cog"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon"><i class="fal fa-sync"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon"><i class="fal fa-database"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon active"><i class="fal fa-film"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon"><i class="fal fa-bullhorn"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings#collapseFive" class="nav-link has-icon"><i class="fal fa-play"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/tmdb-api" class="nav-link has-icon"><i class="fal fa-key"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i></a></li>
              <li class="nav-item ml-auto"><a href="<%=baseUrl%>/settings#about" class="nav-link has-icon"><i class="fal fa-person-sign"></i></a></li>
            </ul>
          </div>
          <div class="card-body">
          <% if (typeof notice !== "undefined" && notice && notice.text) { %>
            <div class="alert alert-<%= notice.ok ? "success" : "danger" %>"><%= notice.text %></div>
          <% } %>
          <h4 class="mb-3">Now Showing movie list</h4>
          <p class="text-muted small">This page uses its own database and powers the <code><%=baseUrl%>/now-showing</code> screen view.</p>
          <h5 class="mt-4">Home poster carousel</h5>
          <p class="text-muted small mb-3">Optional: show your saved list as slides on the main Posterr page (<code><%=baseUrl%>/</code>). Requires at least one movie below with banner and logo (TMDB).</p>
          <form method="post" action="<%=baseUrl%>/settings/now-showing/screen" class="mb-4 pb-4 border-bottom">
            <div class="form-check mb-2">
              <input type="checkbox" class="form-check-input" id="nsListOnHome" name="enableNowShowingListInPoster" value="true" <%= settings.enableNowShowingListInPoster === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="nsListOnHome">Include Now Showing list on the home poster</label>
            </div>
            <div class="form-check mb-3 ml-3">
              <input type="checkbox" class="form-check-input" id="nsListOnlyHome" name="nowShowingListOnly" value="true" <%= settings.nowShowingListOnly === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="nsListOnlyHome">Home poster: only Now Showing slides</label>
            </div>
            <p class="text-muted small mb-3">When <strong>only Now Showing</strong> is on, the home page shows nothing else (no Now Playing, on-demand, Sonarr, etc.) as long as your list has at least one title with art. Turn on <strong>Include on home poster</strong> first.</p>
            <hr class="my-3">
            <h6 class="text-muted text-uppercase small mb-2">Dedicated <code>/now-showing</code> screen</h6>
            <p class="text-muted small mb-3">Optionally mix in random titles from your media server libraries (same selection as <strong>On-demand libraries</strong> on the main Settings page). Your saved list is favored in the rotating feed.</p>
            <div class="form-check mb-3">
              <input type="checkbox" class="form-check-input" id="nsFillFromServer" name="nowShowingFillFromServer" value="true" <%= settings.nowShowingFillFromServer === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="nsFillFromServer">Fill with random library titles</label>
            </div>
            <div class="form-row">
              <div class="col-md-4 mb-3">
                <label for="nsFillLibraryMax">Max library titles per refresh</label>
                <input type="number" class="form-control" id="nsFillLibraryMax" name="nowShowingFillLibraryMax" min="0" max="48" value="<%= typeof settings.nowShowingFillLibraryMax !== 'undefined' ? settings.nowShowingFillLibraryMax : 12 %>">
                <small class="form-text text-muted">0–48. Uses libraries chosen under On-demand on main Settings; the server is queried when needed if the pool is empty (e.g. On Demand disabled or &quot;number of titles&quot; is 0).</small>
              </div>
              <div class="col-md-4 mb-3">
                <label for="nsCuratedWeight">Curated weight</label>
                <input type="number" class="form-control" id="nsCuratedWeight" name="nowShowingCuratedWeight" min="1" max="20" value="<%= typeof settings.nowShowingCuratedWeight !== 'undefined' ? settings.nowShowingCuratedWeight : 4 %>">
                <small class="form-text text-muted">Higher = your list appears more often (1–20).</small>
              </div>
              <div class="col-md-4 mb-3">
                <label for="nsShowtimeCount">Showtimes per title <span class="text-muted small">(upcoming only; last played and now playing are extra)</span></label>
                <input type="number" class="form-control" id="nsShowtimeCount" name="nowShowingShowtimeCount" min="1" max="6" value="<%= Math.max(1, Math.min(6, parseInt(typeof settings.nowShowingShowtimeCount !== 'undefined' ? settings.nowShowingShowtimeCount : 6, 10) || 6)) %>">
                <small class="form-text text-muted">How many <strong>upcoming</strong> showtimes each title gets on <code>/now-showing</code> and TMDB list slides (1–6). Last played and now playing are shown in addition. Auto schedules use this count; manual lists show up to this many entries.</small>
              </div>
            </div>
            <div class="form-check mb-2">
              <input type="checkbox" class="form-check-input" id="nsShowPrices" name="nowShowingShowPrices" value="true" <%= settings.nowShowingShowPrices === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="nsShowPrices">Show ticket prices on <code>/now-showing</code></label>
            </div>
            <div class="d-flex align-items-center mb-3">
              <div class="form-check mb-0">
                <input type="checkbox" class="form-check-input" id="nsAutoPriceEnabled" name="nowShowingAutoPriceEnabled" value="true" <%= settings.nowShowingAutoPriceEnabled === "true" ? "checked" : "" %>>
                <label class="form-check-label" for="nsAutoPriceEnabled">Auto-generate prices for titles without a saved price (curated + library fillers)</label>
              </div>
              <button
                type="button"
                class="btn btn-sm btn-outline-info ml-2"
                data-toggle="popover"
                data-trigger="focus"
                data-placement="right"
                data-html="true"
                title="Auto price rules"
                data-content="Release age pricing:<br>0-4 years: full price<br>5-9 years: 20% off<br>10-19 years: 50% off<br>20-59 years: 80% off<br>60+ years (classic): back to 20% off">
                <i class="fal fa-info-circle"></i>
              </button>
            </div>
            <div class="form-row">
              <div class="col-md-4 mb-3">
                <label for="nsCurrencyCode">Currency</label>
                <select class="form-control" id="nsCurrencyCode" name="nowShowingCurrencyCode">
                  <% var _currencyCode = (typeof settings.nowShowingCurrencyCode !== 'undefined' && settings.nowShowingCurrencyCode) ? String(settings.nowShowingCurrencyCode).toUpperCase() : 'USD'; %>
                  <option value="USD" <%= _currencyCode === "USD" ? "selected" : "" %>>USD ($)</option>
                  <option value="EUR" <%= _currencyCode === "EUR" ? "selected" : "" %>>EUR</option>
                  <option value="GBP" <%= _currencyCode === "GBP" ? "selected" : "" %>>GBP</option>
                  <option value="CAD" <%= _currencyCode === "CAD" ? "selected" : "" %>>CAD</option>
                  <option value="AUD" <%= _currencyCode === "AUD" ? "selected" : "" %>>AUD</option>
                  <option value="NZD" <%= _currencyCode === "NZD" ? "selected" : "" %>>NZD</option>
                  <option value="JPY" <%= _currencyCode === "JPY" ? "selected" : "" %>>JPY</option>
                </select>
                <small class="form-text text-muted">Used for price symbol on <code>/now-showing</code>.</small>
              </div>
              <div class="col-md-4 mb-3">
                <label for="nsAutoPriceMin">Auto price min</label>
                <input type="number" step="0.01" class="form-control" id="nsAutoPriceMin" name="nowShowingAutoPriceMin" min="0" value="<%= typeof settings.nowShowingAutoPriceMin !== 'undefined' ? settings.nowShowingAutoPriceMin : 8 %>">
                <small class="form-text text-muted">Decimal value (for example: 8.50)</small>
              </div>
              <div class="col-md-4 mb-3">
                <label for="nsAutoPriceMax">Auto price max</label>
                <input type="number" step="0.01" class="form-control" id="nsAutoPriceMax" name="nowShowingAutoPriceMax" min="0" value="<%= typeof settings.nowShowingAutoPriceMax !== 'undefined' ? settings.nowShowingAutoPriceMax : 18 %>">
                <small class="form-text text-muted">Decimal value (for example: 19.99)</small>
              </div>
            </div>
            <div class="form-row">
              <div class="col-md-4 mb-3">
                <label for="ns3dPriceExtra">3D price add-on</label>
                <input type="number" step="0.01" class="form-control" id="ns3dPriceExtra" name="nowShowing3dPriceExtra" min="0" value="<%= typeof settings.nowShowing3dPriceExtra !== 'undefined' ? settings.nowShowing3dPriceExtra : 0 %>">
                <small class="form-text text-muted">Decimal value (for example: 1.36)</small>
              </div>
            </div>
            <hr>
            <h6 class="text-muted text-uppercase small mb-2">Auto page cycle</h6>
            <div class="form-check mb-3">
              <input type="checkbox" class="form-check-input" id="nsPageCycleEnabled" name="enableNowShowingPageCycle" value="true" <%= settings.enableNowShowingPageCycle === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="nsPageCycleEnabled">Automatically switch between Home and <code>/now-showing</code></label>
            </div>
            <div class="form-row">
              <div class="col-md-6 mb-3">
                <label for="nsPageCycleEveryMins">Go to <code>/now-showing</code> every (minutes)</label>
                <input type="number" class="form-control" id="nsPageCycleEveryMins" name="nowShowingPageCycleEveryMins" min="1" max="1440" value="<%= typeof settings.nowShowingPageCycleEveryMins !== 'undefined' ? settings.nowShowingPageCycleEveryMins : 30 %>">
                <small class="form-text text-muted">Home slideshow duration before switching to <code>/now-showing</code>.</small>
              </div>
              <div class="col-md-6 mb-3">
                <label for="nsPageCycleStayMins">Stay on <code>/now-showing</code> for (minutes)</label>
                <input type="number" class="form-control" id="nsPageCycleStayMins" name="nowShowingPageCycleStayMins" min="1" max="120" value="<%= typeof settings.nowShowingPageCycleStayMins !== 'undefined' ? settings.nowShowingPageCycleStayMins : 5 %>">
                <small class="form-text text-muted">After this time, the screen returns to Home automatically.</small>
              </div>
            </div>
            <button type="submit" class="btn btn-primary">Save screen options</button>
          </form>
          <h6 class="text-muted text-uppercase small mb-2">Auto showtimes</h6>
          <p class="text-muted small mb-2">Titles in <strong>Auto</strong> mode get a fixed list of times from <strong>local midnight</strong> through the end of that calendar day (spacing from runtime + 10 minutes). Each title has a small random offset after midnight so rows do not line up exactly. When the date changes, schedules are rebuilt for the new day. Adding a movie sets that day’s grid through tonight’s end.</p>
          <form method="post" action="<%=baseUrl%>/settings/now-showing/regenerate-showtimes" class="mb-4 pb-4 border-bottom">
            <button type="submit" class="btn btn-primary">Regenerate all auto showtimes</button>
            <small class="form-text text-muted d-block mt-1">Clears saved auto grids for every auto title so the next load of <code>/now-showing</code> (or TMDB list slides) recomputes today’s day-long schedule.</small>
          </form>
          <div class="form-group">
            <label for="tmdbSearch">Search movie (TMDB)</label>
            <div class="input-group">
              <input id="tmdbSearch" type="text" class="form-control" placeholder="Search title">
              <div class="input-group-append"><button class="btn btn-primary" id="searchBtn">Search</button></div>
            </div>
            <small class="form-text text-muted">Requires <code>TMDB_API_KEY</code> environment variable.</small>
          </div>
          <div id="searchResults" class="mb-4"></div>
          <h6 class="text-muted text-uppercase small mb-2">Saved movies</h6>
          <div id="savedMovies"></div>
        </div></div>
      </div>
    </div>
  </div>
  <% var _nsShowtimeDefault = typeof settings.nowShowingShowtimeCount !== "undefined" ? parseInt(String(settings.nowShowingShowtimeCount), 10) : 6; if (isNaN(_nsShowtimeDefault)) _nsShowtimeDefault = 6; _nsShowtimeDefault = Math.max(1, Math.min(6, _nsShowtimeDefault)); %>
  <script>
    (function () {
      var base = <%- JSON.stringify(baseUrl) %>;
      var listUrl = base + "/settings/now-showing/list";
      var searchUrl = base + "/settings/now-showing/search";
      var addUrl = base + "/settings/now-showing/add";
      var defaultShowings = 6;

      function esc(v){ var d=document.createElement("div"); d.textContent=v==null?"":String(v); return d.innerHTML; }
      function parseManual(v){ return String(v||"").split(",").map(function(s){return s.trim();}).filter(Boolean).slice(0,6); }
      function parsePrice(v){
        var n = parseFloat(String(v == null ? "" : v).trim());
        if (!Number.isFinite(n) || n < 0) return "";
        return String(Math.round(n * 100) / 100);
      }
      function formBody(obj){ return new URLSearchParams(obj); }

      function movieRow(m) {
        var manual = (m.manualTimes || []).join(", ");
        var price = (m.priceAmount != null && m.priceAmount !== "") ? m.priceAmount : "";
        return '<div class="border rounded p-2 mb-2">'+
          '<div class="d-flex justify-content-between align-items-start flex-wrap">'+
            '<div><strong>'+esc(m.title)+'</strong> <span class="text-muted">('+esc(m.year||"") +')</span></div>'+
            '<button class="btn btn-sm btn-outline-danger" data-del="'+m.id+'">Delete</button>'+
          '</div>'+
          '<div class="small text-muted mb-2">TMDB: '+esc(m.tmdbId||"")+' · Runtime: '+esc(m.runtimeMins||"")+'m</div>'+
          '<div class="form-row">'+
            '<div class="col-4"><select class="form-control form-control-sm" data-mode="'+m.id+'"><option value="auto" '+(m.showtimeMode==="auto"?"selected":"")+'>Auto</option><option value="manual" '+(m.showtimeMode==="manual"?"selected":"")+'>Manual</option></select></div>'+
            '<div class="col-3"><input type="number" min="1" max="6" value="'+esc(m.autoShowings != null && m.autoShowings !== "" ? m.autoShowings : defaultShowings)+'" class="form-control form-control-sm" data-showings="'+m.id+'"></div>'+
            '<div class="col-3"><input type="number" min="0" step="0.01" class="form-control form-control-sm" placeholder="Price" value="'+esc(price)+'" data-price="'+m.id+'"></div>'+
            '<div class="col-5"><input type="text" class="form-control form-control-sm" placeholder="1:00 PM, 3:45 PM" value="'+esc(manual)+'" data-manual="'+m.id+'"></div>'+
          '</div>'+
          '<button class="btn btn-sm btn-outline-primary mt-2" data-save="'+m.id+'">Save times</button>'+
        '</div>';
      }

      function loadSaved() {
        fetch(listUrl, { credentials: "same-origin" })
          .then(function(r){ return r.json(); })
          .then(function(data){
            var arr = (data && data.movies) || [];
            document.getElementById("savedMovies").innerHTML = arr.length ? arr.map(movieRow).join("") : '<p class="text-muted small">No movies saved yet.</p>';
          })
          .catch(function(){ document.getElementById("savedMovies").innerHTML = '<p class="text-danger small">Could not load saved movies.</p>'; });
      }

      function searchTmdb() {
        var q = document.getElementById("tmdbSearch").value.trim();
        if (!q) return;
        fetch(searchUrl + "?q=" + encodeURIComponent(q), { credentials: "same-origin" })
          .then(function(r){ return r.json(); })
          .then(function(data){
            if (data.error) throw new Error(data.error);
            var rows = (data.results || []).map(function(m){
              return '<div class="border rounded p-2 mb-2">'+
                '<div><strong>'+esc(m.title)+'</strong> <span class="text-muted">('+esc(m.year||"") +')</span></div>'+
                '<div class="small text-muted mb-2">'+esc(m.overview||"")+'</div>'+
                '<div class="form-row align-items-center">'+
                  '<div class="col-2"><select class="form-control form-control-sm" data-new-mode="'+m.tmdbId+'"><option value="auto" selected>Auto</option><option value="manual">Manual</option></select></div>'+
                  '<div class="col-2"><input type="number" min="1" max="6" value="'+esc(defaultShowings)+'" class="form-control form-control-sm" data-new-showings="'+m.tmdbId+'"></div>'+
                  '<div class="col-2"><input type="number" min="0" step="0.01" class="form-control form-control-sm" placeholder="Price" data-new-price="'+m.tmdbId+'"></div>'+
                  '<div class="col-4"><input type="text" class="form-control form-control-sm" placeholder="Manual times csv" data-new-manual="'+m.tmdbId+'"></div>'+
                  '<div class="col-2"><button class="btn btn-sm btn-success" data-add="'+m.tmdbId+'">Add</button></div>'+
                '</div>'+
              '</div>';
            });
            document.getElementById("searchResults").innerHTML = rows.length ? rows.join("") : '<p class="text-muted small">No matches.</p>';
          })
          .catch(function(e){ document.getElementById("searchResults").innerHTML = '<p class="text-danger small">'+esc(e.message||e)+'</p>'; });
      }

      function post(url, bodyObj) {
        return fetch(url, {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" },
          body: formBody(bodyObj)
        }).then(function(r){ return r.json(); });
      }

      document.addEventListener("click", function (e) {
        var t = e.target;
        if (t.id === "searchBtn") { searchTmdb(); return; }
        if (t.dataset && t.dataset.add) {
          var id = t.dataset.add;
          var mode = document.querySelector('[data-new-mode="'+id+'"]').value;
          var sh = document.querySelector('[data-new-showings="'+id+'"]').value;
          var pr = document.querySelector('[data-new-price="'+id+'"]').value;
          var man = document.querySelector('[data-new-manual="'+id+'"]').value;
          post(addUrl, { tmdbId:id, showtimeMode:mode, autoShowings:sh, priceAmount:parsePrice(pr), manualTimes:parseManual(man).join(",") }).then(function(r){
            if (r.error) throw new Error(r.error);
            loadSaved();
          }).catch(function(err){ alert(err.message || err); });
          return;
        }
        if (t.dataset && t.dataset.del) {
          post(base + "/settings/now-showing/delete/" + encodeURIComponent(t.dataset.del), {}).then(function(){ loadSaved(); });
          return;
        }
        if (t.dataset && t.dataset.save) {
          var sid = t.dataset.save;
          var smode = document.querySelector('[data-mode="'+sid+'"]').value;
          var sshow = document.querySelector('[data-showings="'+sid+'"]').value;
          var sprice = document.querySelector('[data-price="'+sid+'"]').value;
          var sman = document.querySelector('[data-manual="'+sid+'"]').value;
          post(base + "/settings/now-showing/update/" + encodeURIComponent(sid), {
            showtimeMode: smode,
            autoShowings: sshow,
            priceAmount: parsePrice(sprice),
            manualTimes: parseManual(sman).join(",")
          }).then(function(r){
            if (r.error) throw new Error(r.error);
            loadSaved();
          }).catch(function(err){ alert(err.message || err); });
        }
      });

      document.getElementById("tmdbSearch").addEventListener("keydown", function (e) {
        if (e.key === "Enter") { e.preventDefault(); searchTmdb(); }
      });

      if (window.jQuery && jQuery.fn && typeof jQuery.fn.popover === "function") {
        jQuery('[data-toggle="popover"]').popover();
      }

      loadSaved();
    })();
  </script>
</body>
</html>

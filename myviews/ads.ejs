<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover">
  <meta http-equiv="Cache-control" content="public">
  <title>Posterr - Ads</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <style>
    html, body {
      height: 100%;
      margin: 0;
      overflow: hidden;
      background: #000;
      color: #f5f6f7;
    }
    .ads-stage {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      background-color: #000;
    }
    /* Dedicated /ads-view backdrop: blur only applies to this layer, not CSS bg on .ads-stage */
    .ads-global-bg-layer {
      position: absolute;
      inset: -12px;
      z-index: 0;
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      filter: blur(5px);
      transform: scale(1.06);
      transform-origin: center center;
      pointer-events: none;
    }
    .ads-slides {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }
    .ad-slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 700ms ease;
      background: transparent;
      pointer-events: none;
    }
    .ad-slide.is-active {
      opacity: 1;
      z-index: 2;
      pointer-events: auto;
    }
    .ad-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center center;
      background: transparent;
      z-index: 2;
    }
    .ad-image.ad-image--background {
      object-fit: cover;
      filter: blur(2px) brightness(0.7);
      transform: scale(1.03);
      opacity: 0.8;
      z-index: 1;
    }
    .ad-info {
      position: absolute;
      left: calc(var(--img-inset-left, 0px) + clamp(0.8rem, 2vw, 1.4rem));
      right: calc(var(--img-inset-right, 0px) + clamp(0.8rem, 2vw, 1.4rem));
      bottom: calc(var(--img-inset-bottom, 0px) + clamp(0.8rem, 2.2vh, 1.4rem));
      z-index: 4;
      display: flex;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: clamp(0.5rem, 2vw, 1.25rem);
      text-shadow: 0 2px 8px rgba(0,0,0,0.8);
    }
    .ad-info-main {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      min-width: 0;
      flex: 1 1 auto;
      max-width: min(54%, calc(100% - 9rem));
    }
    .ad-name {
      margin: 0;
      font-size: clamp(1rem, 2.2vmin + 0.65vw, 1.7rem);
      font-weight: 700;
      color: #fff;
    }
    .ad-name.ad-name--outline {
      paint-order: stroke fill;
      -webkit-text-stroke: 2.25px rgba(0, 0, 0, 0.94);
      text-shadow:
        0 0 2px rgba(0, 0, 0, 1),
        -1px -1px 0 rgba(0, 0, 0, 0.85),
        1px -1px 0 rgba(0, 0, 0, 0.85),
        -1px 1px 0 rgba(0, 0, 0, 0.85),
        1px 1px 0 rgba(0, 0, 0, 0.85),
        -2px 0 0 rgba(0, 0, 0, 0.55),
        2px 0 0 rgba(0, 0, 0, 0.55),
        0 -2px 0 rgba(0, 0, 0, 0.55),
        0 2px 0 rgba(0, 0, 0, 0.55),
        0 3px 14px rgba(0, 0, 0, 0.8);
    }
    .ad-prices {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
    .ad-addon-section {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      justify-content: flex-end;
      gap: 0.28rem;
      flex: 0 1 auto;
      max-width: min(46%, 15rem);
      text-align: right;
    }
    .ad-addon-section .ad-addon-heading {
      align-self: flex-end;
      text-align: right;
      width: 100%;
      margin: 0;
      /* Same family/weight/color as .ad-name; slightly smaller in the narrow column */
      font-size: clamp(0.82rem, 1.85vmin + 0.5vw, 1.35rem);
      letter-spacing: normal;
      text-transform: none;
    }
    .ad-addon-section .ad-prices {
      align-items: flex-end;
    }
    .ad-price-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.32rem 0.75rem;
      border-radius: 999px;
      background: rgba(13,110,253,0.28);
      border: 1px solid rgba(13,110,253,0.55);
      font-size: clamp(0.78rem, 2.05vmin, 1rem);
      font-weight: 600;
      backdrop-filter: blur(2px);
    }
    .ad-price-pill--c1 { background: rgba(13,110,253,0.32); border-color: rgba(13,110,253,0.65); }
    .ad-price-pill--c2 { background: rgba(40,167,69,0.30); border-color: rgba(40,167,69,0.62); }
    .ad-price-pill--c3 { background: rgba(255,193,7,0.34); border-color: rgba(255,193,7,0.7); color: #1f1f1f; text-shadow: none; }
    .ad-price-pill--c4 { background: rgba(220,53,69,0.32); border-color: rgba(220,53,69,0.65); }
    .ad-price-pill--c5 { background: rgba(111,66,193,0.34); border-color: rgba(111,66,193,0.68); }
    .ad-price-pill--c6 { background: rgba(23,162,184,0.32); border-color: rgba(23,162,184,0.65); }
    .ad-price-pill__title { opacity: 0.95; }
    .ad-price-pill__value { font-weight: 700; display: inline-flex; align-items: baseline; flex-wrap: wrap; gap: 0.15em 0.35em; }
    .ad-price-pill__plus {
      opacity: 0.9;
      margin-right: 0.1em;
      font-weight: 800;
    }
    .ad-price-pill__base { font-weight: 700; }
    .ads-empty {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: #aeb5be;
      font-size: clamp(0.9rem, 2.2vmin, 1rem);
      padding: 1rem;
    }
  </style>
</head>
<body>
  <%- include('new-features-banner.ejs') %>
  <main id="adsStage" class="ads-stage">
    <div id="adsGlobalBgLayer" class="ads-global-bg-layer" aria-hidden="true"></div>
    <section id="adsSlides" class="ads-slides"></section>
  </main>
  <script>
    (function () {
      var adsUrl = <%- JSON.stringify(baseUrl + "/ads/data") %>;
      var assetBase = <%- JSON.stringify(baseUrl) %>;
      var homePostersUrl = <%- JSON.stringify(baseUrl + "/") %>;
      var initialGlobalBg = <%- JSON.stringify(
        typeof adsGlobalBackgroundPath !== "undefined" && adsGlobalBackgroundPath
          ? String(adsGlobalBackgroundPath).trim()
          : ""
      ) %>;
      var slideMs = Math.max(3000, (parseInt(<%- JSON.stringify(String(typeof adsRotationSeconds !== "undefined" ? adsRotationSeconds : 10)) %>, 10) || 10) * 1000);
      var slidesEl = document.getElementById("adsSlides");
      var adsStageEl = document.getElementById("adsStage");
      var adsGlobalBgLayerEl = document.getElementById("adsGlobalBgLayer");
      var cycleTimer = null;
      var currentIndex = 0;
      var pageReturnTimer = null;
      var lastScheduledStaySec = null;
      var adsUrlQs = new URLSearchParams(window.location.search || "");
      var adsCycleEmbed = adsUrlQs.get("cycleEmbed") === "1";
      var adsCycleEmbedStayMins = (function () {
        var n = parseInt(adsUrlQs.get("cycleStayMins") || "0", 10);
        return Number.isFinite(n) && n > 0 ? n : 0;
      })();
      var adsEmbedReturnTimer = null;

      function clampPageStay(raw) {
        if (raw === undefined || raw === null || raw === "") return 0;
        var n = parseInt(raw, 10);
        if (isNaN(n) || n <= 0) return 0;
        return Math.min(86400, Math.max(30, n));
      }

      function scheduleReturnToPosters(pageStayRaw) {
        if (
          adsCycleEmbed &&
          window.parent &&
          window.parent !== window &&
          adsCycleEmbedStayMins > 0
        ) {
          if (pageReturnTimer) {
            clearTimeout(pageReturnTimer);
            pageReturnTimer = null;
          }
          lastScheduledStaySec = null;
          if (adsEmbedReturnTimer) return;
          adsEmbedReturnTimer = setTimeout(function () {
            adsEmbedReturnTimer = null;
            try {
              window.parent.postMessage(
                { type: "posterr-home-cycle-embed-close" },
                window.location.origin
              );
            } catch (e) {}
          }, adsCycleEmbedStayMins * 60 * 1000);
          return;
        }
        var stay = clampPageStay(pageStayRaw);
        if (!stay) {
          if (pageReturnTimer) {
            clearTimeout(pageReturnTimer);
            pageReturnTimer = null;
          }
          lastScheduledStaySec = 0;
          return;
        }
        if (lastScheduledStaySec === stay && pageReturnTimer) return;
        if (pageReturnTimer) clearTimeout(pageReturnTimer);
        lastScheduledStaySec = stay;
        pageReturnTimer = setTimeout(function () {
          window.location.href = homePostersUrl;
        }, stay * 1000);
      }

      function applyGlobalStageBackground(pathStr) {
        var p = pathStr == null ? "" : String(pathStr).trim();
        if (adsStageEl) {
          adsStageEl.style.backgroundImage = "";
        }
        if (!adsGlobalBgLayerEl) return;
        if (p) {
          adsGlobalBgLayerEl.style.backgroundImage =
            "url(" + JSON.stringify(assetBase + p) + ")";
        } else {
          adsGlobalBgLayerEl.style.backgroundImage = "";
        }
      }

      applyGlobalStageBackground(initialGlobalBg);

      function esc(v) {
        var d = document.createElement("div");
        d.textContent = v == null ? "" : String(v);
        return d.innerHTML;
      }

      function stopCycle() {
        if (cycleTimer) {
          clearInterval(cycleTimer);
          cycleTimer = null;
        }
      }

      function showSlide(index) {
        var nodes = slidesEl.querySelectorAll(".ad-slide");
        if (!nodes.length) return;
        for (var i = 0; i < nodes.length; i++) {
          nodes[i].classList.toggle("is-active", i === index);
        }
      }

      function updateInfoInsetsForSlide(slide) {
        if (!slide) return;
        var img = slide.querySelector(".ad-image:not(.ad-image--background)");
        if (!img) return;
        var sw = slide.clientWidth || 0;
        var sh = slide.clientHeight || 0;
        var nw = img.naturalWidth || 0;
        var nh = img.naturalHeight || 0;
        if (!sw || !sh || !nw || !nh) {
          slide.style.setProperty("--img-inset-left", "0px");
          slide.style.setProperty("--img-inset-right", "0px");
          slide.style.setProperty("--img-inset-bottom", "0px");
          return;
        }
        var scale = Math.min(sw / nw, sh / nh);
        var dw = nw * scale;
        var dh = nh * scale;
        var padX = Math.max(0, (sw - dw) / 2);
        var padY = Math.max(0, (sh - dh) / 2);
        slide.style.setProperty("--img-inset-left", String(padX) + "px");
        slide.style.setProperty("--img-inset-right", String(padX) + "px");
        slide.style.setProperty("--img-inset-bottom", String(padY) + "px");
      }

      function updateInfoInsets() {
        var nodes = slidesEl.querySelectorAll(".ad-slide");
        for (var i = 0; i < nodes.length; i++) {
          updateInfoInsetsForSlide(nodes[i]);
        }
      }

      function startCycle() {
        stopCycle();
        var nodes = slidesEl.querySelectorAll(".ad-slide");
        if (nodes.length < 2) return;
        cycleTimer = setInterval(function () {
          currentIndex = (currentIndex + 1) % nodes.length;
          showSlide(currentIndex);
        }, slideMs);
      }

      function render(items, symbol, titleOutline, rotationSeconds) {
        if (rotationSeconds != null && rotationSeconds !== "") {
          var rs = parseInt(rotationSeconds, 10);
          if (!isNaN(rs) && rs >= 3 && rs <= 600) {
            slideMs = rs * 1000;
          }
        }
        if (!Array.isArray(items) || !items.length) {
          slidesEl.innerHTML = '<div class="ads-empty">No ad slides are available yet.</div>';
          stopCycle();
          return;
        }
        var outlineOn = !!titleOutline;
        slidesEl.innerHTML = items.map(function (ad, idx) {
          var prices = Array.isArray(ad.prices) ? ad.prices : [];
          var addons = Array.isArray(ad.addons) ? ad.addons : [];
          var validPrices = prices.filter(function (p) {
            return p && p.amount != null && !isNaN(Number(p.amount));
          });
          var validAddons = addons.filter(function (a) {
            return a && a.amount != null && !isNaN(Number(a.amount));
          });
          var priceHtml = validPrices
            .map(function (p, pi) {
              var t = String((p && p.title) || "").trim();
              var colorClass = "ad-price-pill--c" + String((pi % 6) + 1);
              var base = Number(p.amount);
              var valueInner =
                '<span class="ad-price-pill__base">' + esc(symbol) + esc(base.toFixed(2)) + "</span>";
              return (
                '<span class="ad-price-pill ' + colorClass + '">' +
                (t ? '<span class="ad-price-pill__title">' + esc(t) + "</span>" : "") +
                '<span class="ad-price-pill__value">' + valueInner + "</span>" +
                "</span>"
              );
            })
            .join("");
          var addonHtml = validAddons
            .map(function (a, ai) {
              var t = String((a && a.title) || "").trim();
              var colorClass = "ad-price-pill--c" + String(((validPrices.length + ai) % 6) + 1);
              var base = Number(a.amount);
              var valueInner =
                '<span class="ad-price-pill__plus">+</span><span class="ad-price-pill__base">' +
                esc(symbol) +
                esc(base.toFixed(2)) +
                "</span>";
              return (
                '<span class="ad-price-pill ' + colorClass + '">' +
                (t ? '<span class="ad-price-pill__title">' + esc(t) + "</span>" : "") +
                '<span class="ad-price-pill__value">' + valueInner + "</span>" +
                "</span>"
              );
            })
            .join("");
          var pricesBlock = priceHtml
            ? '<div class="ad-prices">' + priceHtml + "</div>"
            : "";
          var addonsBlock = addonHtml
            ? '<div class="ad-addon-section">' +
              '<p class="ad-name ad-addon-heading' +
              (outlineOn ? " ad-name--outline" : "") +
              '">Addons</p>' +
              '<div class="ad-prices">' +
              addonHtml +
              "</div></div>"
            : "";
          var mainInner =
            (ad.title
              ? '<h2 class="ad-name' +
                (outlineOn ? " ad-name--outline" : "") +
                '">' +
                esc(ad.title) +
                "</h2>"
              : "") +
            pricesBlock;
          return (
            '<article class="ad-slide' + (idx === 0 ? " is-active" : "") + '">' +
              (ad.backgroundMediaPath
                ? '<img class="ad-image ad-image--background" src="' + esc(ad.backgroundMediaPath) + '" alt="" aria-hidden="true">'
                : "") +
              '<img class="ad-image" src="' + esc(ad.mediaPath) + '" alt="' + esc(ad.title || "Ad image") + '">' +
              '<div class="ad-info">' +
                '<div class="ad-info-main">' +
                mainInner +
                "</div>" +
                addonsBlock +
              "</div>" +
            "</article>"
          );
        }).join("");
        var imgs = slidesEl.querySelectorAll(".ad-image");
        imgs.forEach(function (img) {
          if (img.complete) {
            updateInfoInsetsForSlide(img.closest(".ad-slide"));
          } else {
            img.addEventListener("load", function () {
              updateInfoInsetsForSlide(img.closest(".ad-slide"));
            }, { once: true });
          }
        });
        updateInfoInsets();
        currentIndex = 0;
        showSlide(0);
        startCycle();
      }

      function loadAds() {
        fetch(adsUrl, { credentials: "same-origin", cache: "no-store" })
          .then(function (r) { return r.json(); })
          .then(function (payload) {
            applyGlobalStageBackground(
              (payload && payload.globalBackgroundPath) || ""
            );
            scheduleReturnToPosters(payload && payload.pageStaySeconds);
            render(
              (payload && payload.items) || [],
              (payload && payload.currencySymbol) || "$",
              payload && payload.titleOutline,
              payload && payload.rotationSeconds
            );
          })
          .catch(function () {
            slidesEl.innerHTML = '<div class="ads-empty">Could not load ads.</div>';
            stopCycle();
          });
      }

      loadAds();
      setInterval(loadAds, 15000);
      window.addEventListener("resize", updateInfoInsets, { passive: true });
    })();
  </script>
  <%- include('posterr-view-hotkeys.ejs', { baseUrl, viewHotkeysContext }) %>
</body>
</html>

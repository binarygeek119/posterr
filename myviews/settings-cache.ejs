<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js" crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/font-awesome.min.css">
  <title>Posterr — Cache</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
  <style>
    .cache-chart-wrap { position: relative; height: 280px; max-width: 100%; }
    .cache-chart-wrap.tall { height: 360px; }
    @media (min-width: 768px) {
      .cache-chart-wrap.wide { height: 320px; }
    }
    /* Keep cache dashboard readable when a dark theme is active. */
    @media (prefers-color-scheme: dark) {
      .card,
      .card-body,
      #cacheKindTable,
      #posterDbTable,
      #cacheStatusLine,
      #cacheGenerated {
        color: #f1f3f5;
      }
      .small.text-muted,
      .text-muted {
        color: #cfd4da !important;
      }
      #cacheKindTable.table-striped tbody tr:nth-of-type(odd),
      #posterDbTable.table-striped tbody tr:nth-of-type(odd) {
        background-color: rgba(255, 255, 255, 0.06);
      }
      #cacheSummary .bg-light {
        background-color: rgba(255, 255, 255, 0.1) !important;
        border-color: rgba(255, 255, 255, 0.2) !important;
      }
      #cacheKindTable td,
      #cacheKindTable th,
      #posterDbTable td,
      #posterDbTable th {
        border-color: rgba(255, 255, 255, 0.15);
      }
    }
  </style>
</head>
<body>
  <%if(!user.valid){%><script language='javascript'>
    window.location.href = '<%=baseUrl%>/logon';
  </script><%}%>
  <%- include('new-features-banner.ejs') %>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">Posterr</a></li>
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/settings">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Cache</li>
      </ol>
    </nav>

    <div class="row gutters-sm">
      <div class="col-md-4 d-none d-md-block">
        <div class="card">
          <div class="card-body">
            <nav class="nav flex-column nav-pills nav-gap-y-1">
              <a href="<%=baseUrl%>/settings" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-cog"></i><span class="menu">Settings</span>
              </a>
              <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-sync"></i><span class="menu">Sync</span>
              </a>
              <a href="<%=baseUrl%>/settings/now-showing" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-film"></i><span class="menu">Now Showing</span>
              </a>
              <a href="<%=baseUrl%>/settings/ads" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-bullhorn"></i><span class="menu">Ads</span>
              </a>
              <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-key"></i><span class="menu">TMDB API</span>
              </a>
              <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded active">
                <i class="fal fa-database"></i><span class="menu">Cache</span>
              </a>
              <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-debug"></i><span class="menu">Debug</span>
              </a>
              <a href="<%=baseUrl%>/settings#about" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-person-sign"></i><span class="menu">About</span>
              </a>
            </nav>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card">
          <div class="d-none d-md-flex border-bottom py-2 px-3 justify-content-end align-items-center flex-wrap">
            <a href="<%=baseUrl%>/settings#collapseFive" class="nav-link has-icon text-body py-1 mr-3"><i class="fal fa-play"></i><span class="menu">Now Playing</span></a>
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon text-body py-1"><i class="fal fa-film"></i><span class="menu">Now Showing settings</span></a>
          </div>
          <div class="card-header border-bottom mb-3 d-flex d-md-none">
            <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
              <li class="nav-item"><a href="<%=baseUrl%>/settings" class="nav-link has-icon"><i class="fal fa-cog"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon"><i class="fal fa-sync"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon active"><i class="fal fa-database"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon"><i class="fal fa-film"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon"><i class="fal fa-bullhorn"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings#collapseFive" class="nav-link has-icon"><i class="fal fa-play"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/tmdb-api" class="nav-link has-icon"><i class="fal fa-key"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i></a></li>
              <li class="nav-item ml-auto"><a href="<%=baseUrl%>/settings#about" class="nav-link has-icon"><i class="fal fa-person-sign"></i></a></li>
            </ul>
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap align-items-center justify-content-between mb-3">
              <h4 class="mb-0">Poster &amp; media cache</h4>
              <button type="button" class="btn btn-outline-secondary btn-sm" id="cacheRefreshBtn">Refresh</button>
            </div>
            <p class="text-muted small">Counts reflect <code>config/cache/imagecache</code>, <code>config/cache/mp3cache</code>, and <code>config/posterr-poster-metadata.db</code> (SQLite poster index). Library names appear after a sync or on-demand refresh that includes them. On-disk images are grouped by filename pattern and, for registered poster files, the media type stored in the poster DB. Backdrops, banners, and cast images are matched to a library when they share a base name with a registered poster.</p>

            <div id="cacheLoadError" class="alert alert-danger d-none" role="alert"></div>

            <h6 class="text-muted text-uppercase small mb-2">Cache status</h6>
            <p class="small mb-3" id="cacheStatusLine" aria-live="polite">Loading…</p>

            <div class="row text-center mb-4" id="cacheSummary">
              <div class="col-6 col-md-3 mb-2">
                <div class="border rounded py-2 px-1 bg-light">
                  <div class="small text-muted">Poster DB rows</div>
                  <div class="h5 mb-0" id="sumRows">—</div>
                </div>
              </div>
              <div class="col-6 col-md-3 mb-2">
                <div class="border rounded py-2 px-1 bg-light">
                  <div class="small text-muted">Valid poster files</div>
                  <div class="h5 mb-0" id="sumValid">—</div>
                </div>
              </div>
              <div class="col-6 col-md-3 mb-2">
                <div class="border rounded py-2 px-1 bg-light">
                  <div class="small text-muted">Images on disk</div>
                  <div class="h5 mb-0" id="sumImg">—</div>
                </div>
              </div>
              <div class="col-6 col-md-3 mb-2">
                <div class="border rounded py-2 px-1 bg-light">
                  <div class="small text-muted">Theme MP3s</div>
                  <div class="h5 mb-0" id="sumMp3">—</div>
                </div>
              </div>
            </div>

            <div class="table-responsive mb-3">
              <table class="table table-sm table-striped mb-0" id="cacheKindTable" aria-label="Image files by type">
                <thead><tr><th scope="col">Image type</th><th scope="col" class="text-right">Files</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
            <p class="small text-muted mb-4" id="cacheGenerated"></p>

            <div class="row">
              <div class="col-lg-6 mb-4">
                <h6 class="text-muted text-uppercase small">Image files by type (chart)</h6>
                <div class="cache-chart-wrap"><canvas id="chartByCategory"></canvas></div>
              </div>
              <div class="col-lg-6 mb-4">
                <h6 class="text-muted text-uppercase small">Registered posters by media type</h6>
                <div class="cache-chart-wrap"><canvas id="chartMediaType"></canvas></div>
              </div>
            </div>

            <h6 class="text-muted text-uppercase small mb-2">By library — image files (stacked)</h6>
            <p class="small text-muted">People = <code>*-(actor|actress|director|author|artist).jpg</code>; logo = <code>*-logo.png</code> or <code>*-logo.jpg</code>; banner = <code>*-banner.jpg</code>; background = <code>*-art.jpg</code>. Album / book / audiobook / poster use the poster DB media type for registered <code>*.jpg</code> files; other plain JPEGs count as poster; PNG and unmatched files are other.</p>
            <div class="cache-chart-wrap wide tall mb-4"><canvas id="chartByLibrary"></canvas></div>

            <h6 class="text-muted text-uppercase small mb-2">Poster database by library</h6>
            <div class="table-responsive">
              <table class="table table-sm table-striped" id="posterDbTable">
                <thead><tr><th>Library</th><th>Valid</th><th>Missing file</th><th>Media types</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var statsUrl = <%- JSON.stringify(baseUrl + "/settings/cache/stats") %>;
      var charts = { cat: null, media: null, lib: null };

      function fmtBytes(n) {
        if (n == null || isNaN(n)) return "0 B";
        var u = ["B", "KB", "MB", "GB"];
        var i = 0;
        while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
        return (i === 0 ? n : n.toFixed(1)) + " " + u[i];
      }

      function escapeHtml(s) {
        var d = document.createElement("div");
        d.textContent = s;
        return d.innerHTML;
      }

      function destroyChart(key) {
        if (charts[key]) {
          charts[key].destroy();
          charts[key] = null;
        }
      }

      var KIND_ORDER_DEFAULT = ["people", "album", "book", "audiobook", "poster", "logo", "banner", "background", "other"];
      var KIND_LABEL = {
        people: "People",
        album: "Album",
        book: "Book",
        audiobook: "Audiobook",
        poster: "Poster",
        logo: "Logo",
        banner: "Banner",
        background: "Background",
        other: "Other"
      };
      var KIND_COLOR = {
        people: "#fd7e14",
        album: "#198754",
        book: "#6f42c1",
        audiobook: "#0dcaf0",
        poster: "#0d6efd",
        logo: "#e83e8c",
        banner: "#ffc107",
        background: "#6610f2",
        other: "#6c757d"
      };

      function renderCharts(data) {
        var ic = data.imagecache && data.imagecache.byCategory ? data.imagecache.byCategory : {};
        var order = (data.imagecache && data.imagecache.kindOrder) || KIND_ORDER_DEFAULT;
        var labelsCat = [];
        var dataCat = [];
        var colorsCat = [];
        order.forEach(function (k) {
          var v = ic[k] || 0;
          if (v > 0) {
            labelsCat.push(KIND_LABEL[k] || k);
            dataCat.push(v);
            colorsCat.push(KIND_COLOR[k] || "#adb5bd");
          }
        });
        if (!labelsCat.length) {
          labelsCat = ["(no image files)"];
          dataCat = [1];
          colorsCat = ["#dee2e6"];
        }

        destroyChart("cat");
        charts.cat = new Chart(document.getElementById("chartByCategory"), {
          type: "doughnut",
          data: {
            labels: labelsCat,
            datasets: [{ data: dataCat, backgroundColor: colorsCat, borderWidth: 1 }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: "bottom" } }
          }
        });

        var mediaAgg = {};
        (data.posterDb && data.posterDb.byLibrary || []).forEach(function (row) {
          Object.keys(row.byMediaType || {}).forEach(function (k) {
            mediaAgg[k] = (mediaAgg[k] || 0) + row.byMediaType[k];
          });
        });
        var mk = Object.keys(mediaAgg).sort();
        destroyChart("media");
        charts.media = new Chart(document.getElementById("chartMediaType"), {
          type: "pie",
          data: {
            labels: mk.length ? mk : ["(none)"],
            datasets: [{
              data: mk.length ? mk.map(function (k) { return mediaAgg[k]; }) : [1],
              backgroundColor: ["#0d6efd", "#198754", "#ffc107", "#dc3545", "#20c997", "#6f42c1", "#adb5bd"]
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: "bottom" } }
          }
        });

        var libs = (data.imagecache && data.imagecache.byLibrary) || [];
        var libLabels = libs.map(function (r) { return r.name; });
        var ko = (data.imagecache && data.imagecache.kindOrder) || KIND_ORDER_DEFAULT;
        var libDatasets = ko.map(function (k) {
          return {
            label: KIND_LABEL[k] || k,
            data: libLabels.length ? libs.map(function (r) { return r[k] != null ? r[k] : 0; }) : [0],
            backgroundColor: KIND_COLOR[k] || "#adb5bd"
          };
        });
        destroyChart("lib");
        charts.lib = new Chart(document.getElementById("chartByLibrary"), {
          type: "bar",
          data: {
            labels: libLabels.length ? libLabels : ["(no data)"],
            datasets: libDatasets
          },
          options: {
            indexAxis: "y",
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: { stacked: true, beginAtZero: true, ticks: { precision: 0 } },
              y: { stacked: true }
            },
            plugins: { legend: { position: "bottom" } }
          }
        });
      }

      function fillKindTable(data) {
        var tbody = document.querySelector("#cacheKindTable tbody");
        if (!tbody) return;
        tbody.innerHTML = "";
        var ic = (data.imagecache && data.imagecache.byCategory) || {};
        var order = (data.imagecache && data.imagecache.kindOrder) || KIND_ORDER_DEFAULT;
        order.forEach(function (k) {
          var v = ic[k] != null ? ic[k] : 0;
          var tr = document.createElement("tr");
          var tdL = document.createElement("td");
          tdL.textContent = KIND_LABEL[k] || k;
          var tdR = document.createElement("td");
          tdR.className = "text-right";
          tdR.textContent = String(v);
          tr.appendChild(tdL);
          tr.appendChild(tdR);
          tbody.appendChild(tr);
        });
      }

      function fillTable(data) {
        var tb = document.querySelector("#posterDbTable tbody");
        tb.innerHTML = "";
        var rows = (data.posterDb && data.posterDb.byLibrary) || [];
        if (!rows.length) {
          var tr = document.createElement("tr");
          tr.innerHTML = "<td colspan=\"4\" class=\"text-muted\">No poster metadata rows yet. Run a library sync from the Sync page.</td>";
          tb.appendChild(tr);
          return;
        }
        rows.forEach(function (r) {
          var parts = Object.keys(r.byMediaType || {}).map(function (k) {
            return k + ": " + r.byMediaType[k];
          }).join(", ") || "—";
          var tr = document.createElement("tr");
          tr.innerHTML = "<td>" + escapeHtml(r.name) + "</td><td>" + r.valid + "</td><td>" + r.missingFile + "</td><td>" + escapeHtml(parts) + "</td>";
          tb.appendChild(tr);
        });
      }

      function loadStats() {
        document.getElementById("cacheLoadError").classList.add("d-none");
        fetch(statsUrl, { credentials: "same-origin" })
          .then(function (r) {
            if (r.status === 401) throw new Error("Session expired — open Settings and sign in again.");
            if (!r.ok) throw new Error("HTTP " + r.status);
            return r.json();
          })
          .then(function (data) {
            var pdb = data.posterDb || {};
            var ic = data.imagecache || {};
            var m3 = data.mp3cache || {};
            document.getElementById("sumRows").textContent = pdb.rowCount != null ? pdb.rowCount : "0";
            document.getElementById("sumValid").textContent = pdb.rowsWithValidFile != null ? pdb.rowsWithValidFile : "0";
            document.getElementById("sumImg").textContent = (ic.fileCount != null ? ic.fileCount : "0") + " (" + fmtBytes(ic.totalBytes) + ")";
            document.getElementById("sumMp3").textContent = (m3.fileCount != null ? m3.fileCount : "0") + " (" + fmtBytes(m3.totalBytes) + ")";
            var statusEl = document.getElementById("cacheStatusLine");
            var totalRows = pdb.rowCount != null ? pdb.rowCount : 0;
            var miss = pdb.rowsMissingFile != null ? pdb.rowsMissingFile : 0;
            if (totalRows === 0) {
              statusEl.textContent =
                "Poster database is empty — run a library sync (Sync page) to download posters and metadata.";
              statusEl.className = "small mb-3 text-muted";
            } else if (miss > 0) {
              statusEl.textContent =
                miss +
                " of " +
                totalRows +
                " poster DB row(s) reference a missing or invalid file on disk. Re-sync affected libraries or use Clear poster cache on Settings if you want to rebuild. " +
                "If you still use an older data layout, copy images from saved/imagecache into config/cache/imagecache (same filenames) so the app and browser can see them.";
              statusEl.className = "small mb-3 text-warning";
            } else {
              statusEl.textContent =
                "Poster database: every row with a cache file path has a valid image on disk.";
              statusEl.className = "small mb-3 text-muted";
            }
            document.getElementById("cacheGenerated").textContent = data.generatedAt
              ? "Snapshot: " + new Date(data.generatedAt).toLocaleString()
              : "";
            fillKindTable(data);
            renderCharts(data);
            fillTable(data);
          })
          .catch(function (e) {
            var statusEl = document.getElementById("cacheStatusLine");
            if (statusEl) {
              statusEl.textContent = "";
              statusEl.className = "small mb-3 text-muted";
            }
            var ktb = document.querySelector("#cacheKindTable tbody");
            if (ktb) ktb.innerHTML = "";
            document.getElementById("cacheLoadError").textContent = e.message || String(e);
            document.getElementById("cacheLoadError").classList.remove("d-none");
          });
      }

      document.getElementById("cacheRefreshBtn").addEventListener("click", loadStats);
      loadStats();
    })();
  </script>
</body>
</html>

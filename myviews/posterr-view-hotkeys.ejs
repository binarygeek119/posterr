<% var _vhkCtx = typeof viewHotkeysContext !== "undefined" ? viewHotkeysContext : "now-showing-page"; %>
<% var _vhkEnabled = typeof viewHotkeysEnabled !== "undefined" ? String(viewHotkeysEnabled) === "true" : true; %>
<!-- View switch: 1 = home posters, 2 = Now Showing, 3 = Ads (ignored in form fields). On home with an embed, the parent window handles iframe changes. -->
<script>
(function () {
  if (!<%- JSON.stringify(_vhkEnabled) %>) return;
  var baseUrl = <%- JSON.stringify(baseUrl) %>;
  var ctx = <%- JSON.stringify(_vhkCtx) %>;
  function formField(el) {
    if (!el || !el.tagName) return false;
    var t = el.tagName.toLowerCase();
    if (t === "input" || t === "textarea" || t === "select") return true;
    return !!el.isContentEditable;
  }
  function postToParent(view) {
    try {
      if (window.parent && window.parent !== window) {
        window.parent.postMessage(
          { type: "posterr-view-switch", view: view },
          window.location.origin
        );
      }
    } catch (e) {}
  }
  document.addEventListener(
    "keydown",
    function (ev) {
      if (ev.defaultPrevented || ev.ctrlKey || ev.metaKey || ev.altKey) return;
      if (formField(ev.target)) return;
      var k = ev.key;
      if (k !== "1" && k !== "2" && k !== "3") return;
      ev.preventDefault();
      if (ctx === "now-showing-page" || ctx === "ads-page") {
        if (k === "1") window.location.href = baseUrl + "/posters";
        else if (k === "2") window.location.href = baseUrl + "/now-showing";
        else if (k === "3") window.location.href = baseUrl + "/ads";
        return;
      }
      if (ctx === "embed-now-showing") {
        if (k === "1") postToParent("posters");
        else if (k === "2") postToParent("now-showing");
        else if (k === "3") postToParent("ads");
        return;
      }
      if (ctx === "embed-ads") {
        if (k === "1") postToParent("posters");
        else if (k === "2") postToParent("now-showing");
        else if (k === "3") postToParent("ads");
      }
    },
    true
  );
})();
</script>

<!doctype html>
<html lang="en" class="now-showing-scale">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover">
  <meta http-equiv="Cache-control" content="public">
  <title>Posterr - Now Showing</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/styles.css">
  <style>
    /**
     * Poster-style scaling: root em blends vmin (shorter edge) and vw so type and
     * cards respond to both window height and width (wide/short layouts included).
     */
    html.now-showing-scale {
      font-size: clamp(11px, 2.35vmin + 0.72vw, 26px);
    }
    html,
    body {
      height: 100%;
      max-height: 100%;
      overflow: hidden;
      margin: 0;
    }
    body {
      background: #0f1115;
      color: #f5f6f7;
    }
    body.now-showing-page {
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 100vh;
      min-height: 100dvh;
    }
    .topbar {
      position: relative;
      z-index: 12;
      flex-shrink: 0;
      background: rgba(15, 17, 21, 0.95);
      backdrop-filter: blur(4px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding-top: 0.85rem;
      padding-bottom: 0.85rem;
      --now-showing-side-pad: max(
        clamp(1rem, 5vw, 2.75rem),
        env(safe-area-inset-left, 0px)
      );
      --now-showing-side-pad-right: max(
        clamp(1rem, 5vw, 2.75rem),
        env(safe-area-inset-right, 0px)
      );
      padding-left: var(--now-showing-side-pad);
      padding-right: var(--now-showing-side-pad-right);
    }
    .now-showing-clock {
      position: absolute;
      right: var(--now-showing-side-pad-right, max(0.75rem, env(safe-area-inset-right, 0px)));
      top: 50%;
      transform: translateY(-50%);
      margin: 0;
      font-size: clamp(0.9rem, 2.5vmin + 0.45vw, 1.3rem);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.03em;
      color: rgba(230, 233, 238, 0.95);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
      white-space: nowrap;
      pointer-events: none;
    }
    .now-showing-list-shell {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
      width: 100%;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      box-sizing: border-box;
      padding-left: max(
        clamp(1rem, 5vw, 2.75rem),
        env(safe-area-inset-left, 0px)
      );
      padding-right: max(
        clamp(1rem, 5vw, 2.75rem),
        env(safe-area-inset-right, 0px)
      );
    }
    .now-showing-top-fade {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: clamp(3.25rem, 8.5vmin, 5.5rem);
      z-index: 4;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        rgba(15, 17, 21, 1) 0%,
        rgba(15, 17, 21, 0.94) 18%,
        rgba(15, 17, 21, 0.65) 42%,
        rgba(15, 17, 21, 0.22) 72%,
        rgba(15, 17, 21, 0) 100%
      );
    }
    .now-showing-bottom-fade {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: clamp(3.25rem, 8.5vmin, 5.5rem);
      z-index: 4;
      pointer-events: none;
      background: linear-gradient(
        to top,
        rgba(15, 17, 21, 1) 0%,
        rgba(15, 17, 21, 0.94) 18%,
        rgba(15, 17, 21, 0.65) 42%,
        rgba(15, 17, 21, 0.22) 72%,
        rgba(15, 17, 21, 0) 100%
      );
    }
    .now-showing-title {
      margin: 0;
      max-width: calc(100% - 9rem);
      font-size: clamp(1.35rem, 3.6vmin + 0.85vw, 2.75rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: 0.02em;
      color: lightgoldenrodyellow;
    }
    .scroll-pane {
      height: 100%;
      overflow-y: auto;
      scroll-behavior: auto;
      padding: 0.75rem 0 2rem;
      position: relative;
      z-index: 1;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .ns-loop-wrap {
      position: relative;
    }
    .scroll-pane::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }
    .movie-card {
      position: relative;
      border-radius: 0.625rem;
      overflow: hidden;
      margin-bottom: 0.75rem;
      min-height: clamp(10rem, 24vmin + 1.75vw, 16.5rem);
      background: #1a1f28;
      box-shadow: 0 0.5rem 1.375rem rgba(0, 0, 0, 0.35);
    }
    .movie-card.movie-card--ticker .movie-overlay {
      padding-bottom: 2.5rem;
    }
    .movie-card--now-playing {
      box-shadow:
        0 0 0 3px rgba(251, 191, 36, 0.95),
        0 0 24px rgba(251, 191, 36, 0.35),
        0 8px 22px rgba(0, 0, 0, 0.45);
    }
    .movie-card--now-playing .movie-banner {
      opacity: 0.82;
    }
    .now-showing-live-badge {
      position: absolute;
      top: 0.5rem;
      left: 0.625rem;
      z-index: 6;
      font-size: clamp(0.6rem, 1.65vmin, 0.72rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #0f1115;
      background: linear-gradient(135deg, #fcd34d, #f59e0b);
      padding: 0.25rem 0.625rem;
      border-radius: 0.3125rem;
      box-shadow: 0 0.125rem 0.625rem rgba(0, 0, 0, 0.45);
      pointer-events: none;
    }
    .movie-banner {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      opacity: 0.75;
      transform: scale(1.01);
    }
    .movie-overlay {
      position: relative;
      z-index: 1;
      min-height: clamp(10rem, 24vmin + 1.75vw, 16.5rem);
      padding: 0.875rem 1rem;
      background: linear-gradient(90deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.54) 50%, rgba(0,0,0,0.22) 100%);
    }
    .movie-overlay--has-live-badge {
      padding-top: 2.25rem;
    }
    .movie-overlay-row {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem 1.125rem;
      min-height: clamp(7.5rem, 18.5vmin + 1.25vw, 12.5rem);
    }
    .movie-overlay-row--solo .movie-logo-stack {
      flex: 1 1 100%;
      max-width: 100%;
    }
    .movie-overlay-row--solo .movie-logo-stack .movie-logo {
      justify-content: flex-start;
    }
    .movie-overlay-row--solo .movie-logo-stack .movie-logo img {
      max-width: min(96%, calc(28rem + 18vw));
    }
    .movie-logo-stack {
      flex: 1 1 min(11.25rem, 30vw);
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: clamp(0.75rem, 2.2vmin, 1.25rem);
    }
    .movie-logo {
      font-weight: 700;
      line-height: 1.12;
      letter-spacing: 0.01em;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      text-shadow:
        0 0 1px rgba(0, 0, 0, 1),
        0 1px 3px rgba(0, 0, 0, 0.95),
        0 2px 10px rgba(0, 0, 0, 0.85),
        0 0 18px rgba(0, 0, 0, 0.65);
    }
    .showtimes--under-logo {
      justify-content: flex-start;
      max-width: 100%;
    }
    .price-under-logo {
      justify-content: flex-start;
      max-width: 100%;
      margin-top: 0.1rem;
      margin-bottom: 0.15rem;
    }
    .price-under-logo:not(:empty) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
    .showtimes.showtimes--under-logo:not(:empty) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
    .showtimes--under-logo:empty,
    .showtimes--future:empty {
      display: none;
    }
    .movie-logo--text {
      font-size: clamp(1.1rem, 3.45vmin, 1.85rem);
      max-width: 100%;
    }
    .movie-logo img {
      display: block;
      max-height: clamp(4.65rem, 16vmin + 1.75vw, 10.5rem);
      max-width: min(94%, calc(22rem + 15vw));
      width: auto;
      height: auto;
      object-fit: contain;
      object-position: left center;
      filter:
        drop-shadow(0 1px 2px rgba(0, 0, 0, 1))
        drop-shadow(0 2px 8px rgba(0, 0, 0, 0.9))
        drop-shadow(0 0 14px rgba(0, 0, 0, 0.75))
        drop-shadow(0 0 24px rgba(0, 0, 0, 0.5));
    }
    .movie-meta-column {
      flex: 0 1 auto;
      max-width: min(52%, calc(16rem + 18vw));
      min-width: 9.25rem;
      margin-left: auto;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.625rem;
    }
    .movie-meta-column .pill-row {
      justify-content: flex-end;
      gap: 0.5rem;
    }
    .movie-meta-column .showtimes--future {
      align-items: stretch;
      width: 100%;
      max-width: 100%;
    }
    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      padding: 0.3125rem 0.875rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.22);
      font-size: clamp(0.82rem, 2.35vmin, 1.05rem);
      font-weight: 600;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }
    .pill--cast {
      background: rgba(168, 85, 247, 0.28);
      border-color: rgba(192, 132, 252, 0.72);
      color: #f3e8ff;
      box-shadow: 0 0 0 1px rgba(192, 132, 252, 0.28);
    }
    .pill--rating-g {
      background: rgba(34, 197, 94, 0.32);
      border-color: rgba(74, 222, 128, 0.78);
      color: #ecfdf3;
    }
    .pill--rating-pg {
      background: rgba(132, 204, 22, 0.30);
      border-color: rgba(163, 230, 53, 0.72);
      color: #f7fee7;
    }
    .pill--rating-pg13 {
      background: rgba(251, 191, 36, 0.32);
      border-color: rgba(252, 211, 77, 0.76);
      color: #fffbeb;
    }
    .pill--rating-r {
      background: rgba(239, 68, 68, 0.34);
      border-color: rgba(248, 113, 113, 0.82);
      color: #fef2f2;
    }
    .pill--rating-default {
      background: rgba(244, 63, 94, 0.34);
      border-color: rgba(251, 113, 133, 0.78);
      color: #fff1f2;
    }
    .showtimes {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
    /** Future list: fixed columns per row (same layout at any viewport width). */
    .showtimes.showtimes--future {
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: stretch;
      gap: 0.45rem;
      width: 100%;
      max-width: 100%;
    }
    .showtimes-row {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: flex-end;
      align-items: stretch;
      gap: 0.375rem;
      width: 100%;
      max-width: 100%;
    }
    .showtime-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.28em;
      background: rgba(13, 110, 253, 0.24);
      border-color: rgba(13, 110, 253, 0.48);
    }
    /**
     * Future rows only: equal pill footprint per cell (padding + width) so times align in a grid.
     */
    .showtimes-row .showtime-pill {
      box-sizing: border-box;
      flex: 0 0 clamp(4.85rem, 19vmin, 6rem);
      width: clamp(4.85rem, 19vmin, 6rem);
      min-width: clamp(4.85rem, 19vmin, 6rem);
      max-width: clamp(4.85rem, 19vmin, 6rem);
      justify-content: center;
      padding-left: 0.55rem;
      padding-right: 0.55rem;
    }
    .showtimes-row .showtime-pill .showtime-pill__time {
      flex: 1 1 auto;
      min-width: 0;
      text-align: center;
      font-variant-numeric: tabular-nums;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .showtime-pill__icon {
      display: none;
      flex-shrink: 0;
      line-height: 0;
      opacity: 0.92;
    }
    .showtime-pill__icon svg {
      display: block;
      width: 0.72em;
      height: 0.72em;
      min-width: 10px;
      min-height: 10px;
    }
    .showtime-pill.showtime-pill--current .showtime-pill__icon--play {
      display: block;
    }
    .showtime-pill.showtime-pill--past .showtime-pill__icon--stop {
      display: block;
    }
    .showtime-pill.showtime-pill--current {
      background: linear-gradient(135deg, rgba(52, 211, 153, 0.55), rgba(16, 185, 129, 0.65));
      border-color: rgba(16, 185, 129, 0.95);
      color: #0a0f0d;
      font-weight: 700;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.35), 0 0 14px rgba(16, 185, 129, 0.45);
    }
    .showtime-pill.showtime-pill--past {
      background: linear-gradient(135deg, rgba(248, 113, 113, 0.4), rgba(220, 38, 38, 0.5));
      border-color: rgba(248, 113, 113, 0.95);
      color: #fff;
      font-weight: 700;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.25), 0 0 12px rgba(220, 38, 38, 0.35);
    }
    .movie-card--schedule-active {
      box-shadow:
        0 0 0 2px rgba(16, 185, 129, 0.75),
        0 0 20px rgba(16, 185, 129, 0.28),
        0 8px 22px rgba(0, 0, 0, 0.4);
    }
    .movie-card--schedule-active.movie-card--now-playing {
      box-shadow:
        0 0 0 3px rgba(251, 191, 36, 0.95),
        0 0 24px rgba(251, 191, 36, 0.35),
        0 8px 22px rgba(0, 0, 0, 0.45);
    }
    .muted-empty {
      color: #aeb5be;
      font-size: clamp(0.85rem, 2.2vmin, 1rem);
      padding: 1rem;
      text-align: center;
    }
    .movie-ticker {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 4;
      height: clamp(1.75rem, 5vmin, 2.25rem);
      background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.88) 35%);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      padding-bottom: 0.25rem;
      pointer-events: none;
    }
    .movie-ticker::before,
    .movie-ticker::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: clamp(1.75rem, 5vmin, 2.75rem);
      z-index: 2;
      pointer-events: none;
    }
    .movie-ticker::before {
      left: 0;
      background: linear-gradient(
        to right,
        rgba(0, 0, 0, 0.94) 0%,
        rgba(0, 0, 0, 0.72) 35%,
        rgba(0, 0, 0, 0.2) 75%,
        transparent 100%
      );
    }
    .movie-ticker::after {
      right: 0;
      background: linear-gradient(
        to left,
        rgba(0, 0, 0, 0.94) 0%,
        rgba(0, 0, 0, 0.72) 35%,
        rgba(0, 0, 0, 0.2) 75%,
        transparent 100%
      );
    }
    .movie-ticker-track {
      position: relative;
      z-index: 1;
      display: flex;
      width: max-content;
      transform: translateX(0);
      animation: none;
      will-change: transform;
    }
    .movie-ticker-track.movie-ticker-track--running {
      animation: now-showing-ticker var(--ticker-duration, 40s) linear infinite;
    }
    .movie-ticker-buffer {
      flex-shrink: 0;
      width: clamp(2.25rem, 18%, 6.5rem);
      pointer-events: none;
    }
    .movie-ticker-track span.movie-ticker-text {
      flex-shrink: 0;
      padding-right: 4rem;
      white-space: nowrap;
      font-size: 0.8125rem;
      line-height: 1.25;
      color: #dce1e8;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9);
    }
    @keyframes now-showing-ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .movie-ticker-buffer {
        display: none;
      }
      .movie-ticker-track,
      .movie-ticker-track.movie-ticker-track--running {
        animation: none !important;
        justify-content: center;
        width: 100% !important;
        flex-wrap: wrap;
        white-space: normal;
      }
      .movie-ticker-track span.movie-ticker-text:last-child {
        display: none;
      }
      .movie-ticker-track span.movie-ticker-text {
        white-space: normal;
        text-align: center;
        padding-right: 0;
      }
    }
  </style>
  <% if (typeof custBrand !== "undefined" && custBrand != null && String(custBrand).trim() !== "") { %>
  <style>.now-showing-title { font-family: <%- JSON.stringify(String(custBrand).trim()) %>, sans-serif; }</style>
  <% } %>
  <% if (typeof titleColour !== "undefined" && titleColour != null && String(titleColour).trim() !== "") { %>
  <style>.now-showing-title { color: <%= titleColour %>; }</style>
  <% } %>
</head>
<body class="now-showing-page">
  <%- include('new-features-banner.ejs') %>
  <header class="topbar">
    <time id="nsTopClock" class="now-showing-clock" datetime=""></time>
    <h1 class="now-showing-title">Now Showing</h1>
  </header>

  <div class="now-showing-list-shell">
    <div class="now-showing-top-fade" aria-hidden="true"></div>
    <div id="movieList" class="scroll-pane">
      <div class="ns-loop-wrap" id="nsLoopWrap" hidden></div>
    </div>
    <div class="now-showing-bottom-fade" aria-hidden="true"></div>
  </div>

  <script>
    (function () {
      var nsCycleEnabled = <%- JSON.stringify(String(typeof nowShowingPageCycleEnabled !== "undefined" ? nowShowingPageCycleEnabled : "false")) %> === "true";
      var nsCycleStayMins = parseInt(<%- JSON.stringify(String(typeof nowShowingPageCycleStayMins !== "undefined" ? nowShowingPageCycleStayMins : "5")) %>, 10);
      var nsUrlQs = new URLSearchParams(window.location.search || "");
      var nsCycleEmbed = nsUrlQs.get("cycleEmbed") === "1";
      if (nsCycleEnabled && Number.isFinite(nsCycleStayMins) && nsCycleStayMins > 0) {
        setTimeout(function () {
          if (nsCycleEmbed && window.parent && window.parent !== window) {
            try {
              window.parent.postMessage(
                { type: "posterr-home-cycle-embed-close" },
                window.location.origin
              );
            } catch (e) {}
          } else {
            window.location.href = <%- JSON.stringify(baseUrl + "/posters") %>;
          }
        }, nsCycleStayMins * 60 * 1000);
      }
      var cardsUrl = <%- JSON.stringify(baseUrl + "/now-showing/data") %>;
      var fallbackBanner = <%- JSON.stringify(baseUrl + "/images/no-poster-available.png") %>;
      var settingsVersion = <%- JSON.stringify(String(typeof settingsVersion !== "undefined" ? settingsVersion : "0")) %>;
      var MAX_LOOP_CARDS = 100;
      var curatedWeight = 4;
      var sourceMovies = [];
      var listEl = document.getElementById("movieList");
      var loopWrap = document.getElementById("nsLoopWrap");
      var autoScrollTimer = null;
      var segResizeObs = null;
      var segmentHeightPx = 0;
      var lastStructSig = null;
      var lastPlayingSig = null;
      var showtimeDisplayMax = 6;
      var showPricesEnabled = false;
      var currencySymbol = "$";
      var reduceMotion =
        typeof window.matchMedia === "function" &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      /** @type {IntersectionObserver[]} */
      var tickerObservers = [];
      var scheduleHighlightTimer = null;
      /** Per title (data-ns-key): rolling auto showtimes shared across loop duplicate cards. */
      var showtimeSlotStateByKey = {};
      var SHOWTIME_PLAY_ICON =
        '<span class="showtime-pill__icon showtime-pill__icon--play" aria-hidden="true">' +
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" focusable="false">' +
        '<path fill="currentColor" d="M2 1.5v9l7.2-4.5L2 1.5z"/>' +
        "</svg></span>";
      var SHOWTIME_STOP_ICON =
        '<span class="showtime-pill__icon showtime-pill__icon--stop" aria-hidden="true">' +
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" focusable="false">' +
        '<rect fill="currentColor" x="2.25" y="2.25" width="7.5" height="7.5" rx="1.2"/>' +
        "</svg></span>";

      function esc(s) {
        var d = document.createElement("div");
        d.textContent = s == null ? "" : String(s);
        return d.innerHTML;
      }

      function runtimeLabel(mins) {
        var n = parseInt(mins, 10);
        if (!n || n < 1) return "";
        var h = Math.floor(n / 60);
        var m = n % 60;
        if (h <= 0) return m + "m";
        if (m === 0) return h + "h";
        return h + "h " + m + "m";
      }

      function ratingPillClass(contentRating) {
        var v = String(contentRating || "").toUpperCase().trim();
        if (v === "G") return "pill--rating-g";
        if (v === "PG") return "pill--rating-pg";
        if (v === "PG-13" || v === "PG13") return "pill--rating-pg13";
        if (v === "R") return "pill--rating-r";
        return "pill--rating-default";
      }

      function randomShowtimes(maxCount) {
        var count = Math.min(6, Math.max(1, parseInt(maxCount, 10) || 6));
        var now = new Date();
        var startHour = 10 + Math.floor(Math.random() * 3);
        var t = new Date(now.getFullYear(), now.getMonth(), now.getDate(), startHour, 0, 0, 0);
        var out = [];
        for (var i = 0; i < count; i++) {
          var addMins = 105 + Math.floor(Math.random() * 70);
          t = new Date(t.getTime() + addMins * 60000);
          out.push(t.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" }));
        }
        return out;
      }

      function hasNowShowingBannerAndLogo(m) {
        var logo = String(m.logo || "").trim();
        var banner = String(m.banner || "").trim();
        return (
          logo !== "" &&
          banner !== "" &&
          banner !== String(fallbackBanner || "").trim()
        );
      }

      function cardsToMovies(rows) {
        return (rows || [])
          .map(function (c) {
            var rt = parseInt(c.runtimeMins, 10);
            if (!rt || rt < 1 || isNaN(rt)) rt = 120;
            return {
              id: c.id,
              tmdbId: c.tmdbId,
              title: c.title || "Untitled",
              logo: c.logoURL || c.logoUrl || c.posterLogoURL || "",
              banner: c.bannerUrl || fallbackBanner,
              year: c.year || "",
              rating: c.ratingScore || c.rating || "",
              contentRating: c.ratingContent || c.contentRating || "",
              studio: c.studio || "",
              topCast: c.topCast || "",
              topCastList: (function () {
                var explicit = [String(c.actor1 || "").trim(), String(c.actor2 || "").trim()]
                  .filter(Boolean)
                  .slice(0, 2);
                if (explicit.length) return explicit;
                return String(c.topCast || "")
                  .split(",")
                  .map(function (x) { return x.trim(); })
                  .filter(Boolean)
                  .slice(0, 2);
              })(),
              runtime: runtimeLabel(c.runtimeMins),
              runtimeMins: rt,
              mediaType: c.mediaType || "",
              genreList: String(c.genres || "")
                .split(",")
                .map(function (x) { return x.trim(); })
                .filter(Boolean)
                .slice(0, 3),
              tagLine: String(c.tagLine || "").trim(),
              showtimes: Array.isArray(c.showtimes) ? c.showtimes : [],
              showtimeStartsIso: Array.isArray(c.showtimeStartsIso) ? c.showtimeStartsIso : [],
              showtimeMode: c.showtimeMode === "manual" ? "manual" : "auto",
              priceAmount:
                c.priceAmount !== undefined && c.priceAmount !== null
                  ? Number(c.priceAmount)
                  : null,
              price3dAmount:
                c.price3dAmount !== undefined && c.price3dAmount !== null
                  ? Number(c.price3dAmount)
                  : null,
              is3D: c.is3D === true,
              isCurated: c.isCurated !== false,
              isNowPlaying: c.isNowPlaying === true,
              plot: String(c.plot || c.overview || c.summary || c.tagLine || c.title || "")
                .replace(/\s+/g, " ")
                .trim()
            };
          })
          .filter(hasNowShowingBannerAndLogo);
      }

      function weightedShufflePool(items, weight) {
        var w = Math.max(1, parseInt(weight, 10) || 1);
        var pool = [];
        for (var i = 0; i < items.length; i++) {
          var m = items[i];
          var reps = m.isCurated ? w : 1;
          for (var r = 0; r < reps; r++) pool.push(m);
        }
        for (var j = pool.length - 1; j > 0; j--) {
          var k = Math.floor(Math.random() * (j + 1));
          var tmp = pool[j];
          pool[j] = pool[k];
          pool[k] = tmp;
        }
        return pool;
      }

      function stableNsKey(m) {
        var id = m.tmdbId != null && m.tmdbId !== "" ? "t" + String(m.tmdbId) : "";
        if (!id && m.id != null && m.id !== "") id = "i" + String(m.id);
        if (!id) id = "n";
        return id + "|" + String(m.title || "").toLowerCase().trim() + "|" + String(m.year || "");
      }

      /** Same key as stableNsKey, for API payload rows (before cardsToMovies filter). */
      function stableNsKeyFromRaw(c) {
        var id = c.tmdbId != null && c.tmdbId !== "" ? "t" + String(c.tmdbId) : "";
        if (!id && c.id != null && c.id !== "") id = "i" + String(c.id);
        if (!id) id = "n";
        return id + "|" + String(c.title || "").toLowerCase().trim() + "|" + String(c.year || "");
      }

      function structSigFromCards(cards) {
        return JSON.stringify(
          (cards || []).map(function (c) {
            var o = {};
            for (var k in c) {
              if (Object.prototype.hasOwnProperty.call(c, k) && k !== "isNowPlaying") {
                o[k] = c[k];
              }
            }
            return o;
          })
        );
      }

      function normalizeSlotStartsMs(arr) {
        var a = (arr || []).slice().sort(function (x, y) { return x - y; });
        var out = [];
        for (var i = 0; i < a.length; i++) {
          if (i === 0 || a[i] !== a[i - 1]) out.push(a[i]);
        }
        return out;
      }

      function findCurrentShowtimeIndex(slotsMs, nowMs, runtimeMs) {
        for (var i = 0; i < slotsMs.length; i++) {
          if (nowMs >= slotsMs[i] && nowMs < slotsMs[i] + runtimeMs) return i;
        }
        return -1;
      }

      function showtimePillMarkup(isoMs, kind) {
        var d = new Date(isoMs);
        var iso = d.toISOString();
        var label = d.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" });
        var cls = "pill showtime-pill";
        if (kind === "current") cls += " showtime-pill--current";
        else if (kind === "past") cls += " showtime-pill--past";
        return (
          '<span class="' +
          cls +
          '" data-st-iso="' +
          esc(iso) +
          '">' +
          SHOWTIME_PLAY_ICON +
          SHOWTIME_STOP_ICON +
          '<span class="showtime-pill__time">' +
          esc(label) +
          "</span></span>"
        );
      }

      function futurePillFromLabelOnly(label) {
        return (
          '<span class="pill showtime-pill">' +
          SHOWTIME_PLAY_ICON +
          SHOWTIME_STOP_ICON +
          '<span class="showtime-pill__time">' +
          esc(label) +
          "</span></span>"
        );
      }

      /** Three columns per row for future times (up to 3 rows at 8 slots). */
      var FUTURE_SHOWTIMES_PER_ROW = 3;

      function wrapShowtimePillsInRows(pillHtmlStrings, perRow) {
        var n = Math.max(1, Math.min(10, parseInt(perRow, 10) || FUTURE_SHOWTIMES_PER_ROW));
        var list = pillHtmlStrings || [];
        if (!list.length) return "";
        var out = [];
        for (var i = 0; i < list.length; i += n) {
          out.push(
            '<div class="showtimes-row">' + list.slice(i, i + n).join("") + "</div>"
          );
        }
        return out.join("");
      }

      function buildFutureShowtimesRowedHtml(sortedMsList) {
        if (!sortedMsList || !sortedMsList.length) return "";
        var uniq = normalizeSlotStartsMs(
          sortedMsList.slice().sort(function (a, b) {
            return a - b;
          })
        );
        var pillStrs = [];
        for (var fi = 0; fi < uniq.length; fi++) {
          pillStrs.push(showtimePillMarkup(uniq[fi], "future"));
        }
        return wrapShowtimePillsInRows(pillStrs, FUTURE_SHOWTIMES_PER_ROW);
      }

      function buildFutureShowtimesFromTimesAndIsos(times, isos) {
        var isoMsSeq = [];
        var noIsoTimes = [];
        for (var i = 0; i < times.length; i++) {
          var iso = isos[i];
          var isoMs = iso && typeof iso === "string" ? Date.parse(iso) : NaN;
          if (!isNaN(isoMs)) isoMsSeq.push(isoMs);
          else noIsoTimes.push(times[i]);
        }
        var uniq = normalizeSlotStartsMs(
          isoMsSeq.slice().sort(function (a, b) {
            return a - b;
          })
        );
        var pillStrs = [];
        for (var j = 0; j < uniq.length; j++) {
          pillStrs.push(showtimePillMarkup(uniq[j], "future"));
        }
        for (var k = 0; k < noIsoTimes.length; k++) {
          pillStrs.push(futurePillFromLabelOnly(noIsoTimes[k]));
        }
        return wrapShowtimePillsInRows(pillStrs, FUTURE_SHOWTIMES_PER_ROW);
      }

      function buildMovieCardHtml(m) {
        var nsKey = stableNsKey(m);
        var pills = [];
        var castPills = [];
        if (!m.isCurated) pills.push('<span class="pill">Library</span>');
        if (m.is3D) pills.push('<span class="pill">3D</span>');
        if (m.mediaType) pills.push('<span class="pill">' + esc(String(m.mediaType).toUpperCase()) + "</span>");
        if (m.year) pills.push('<span class="pill">' + esc(m.year) + "</span>");
        if (m.studio) pills.push('<span class="pill">' + esc(m.studio) + "</span>");
        if (m.runtime) pills.push('<span class="pill">' + esc(m.runtime) + "</span>");
        if (m.rating) pills.push('<span class="pill">' + esc(m.rating) + "</span>");
        if (Array.isArray(m.topCastList)) {
          for (var ci = 0; ci < m.topCastList.length; ci++) {
            castPills.push('<span class="pill pill--cast">' + esc(m.topCastList[ci]) + "</span>");
          }
        }
        if (m.contentRating) pills.push('<span class="pill ' + ratingPillClass(m.contentRating) + '">' + esc(m.contentRating) + "</span>");
        if (Array.isArray(m.genreList)) {
          for (var gi = 0; gi < m.genreList.length; gi++) {
            pills.push('<span class="pill">' + esc(m.genreList[gi]) + "</span>");
          }
        }

        var showtimeMarkupUnder = "";
        var priceMarkupUnder = "";
        var showtimeMarkupFuture = "";
        var initialSlotsAttr = "";
        if (showPricesEnabled && m.priceAmount != null && !isNaN(m.priceAmount)) {
          var pricePills = [];
          if (m.is3D && m.price3dAmount != null && !isNaN(m.price3dAmount)) {
            pricePills.push(
              '<span class="pill">3D ' +
                esc(currencySymbol) +
                esc(m.price3dAmount.toFixed(2)) +
                "</span>"
            );
            pricePills.push(
              '<span class="pill">' +
                esc(currencySymbol) +
                esc(m.priceAmount.toFixed(2)) +
                "</span>"
            );
          } else {
            pricePills.push(
              '<span class="pill">' +
                esc(currencySymbol) +
                esc(m.priceAmount.toFixed(2)) +
                "</span>"
            );
          }
          priceMarkupUnder =
            '<div class="showtimes price-under-logo">' +
            pricePills.join("") +
            "</div>";
        }
        if (m.showtimes && m.showtimes.length) {
          var futureCap = Math.max(1, Math.min(6, showtimeDisplayMax || 6));
          var slotCap = Math.min(8, futureCap + 2);
          var times = m.showtimes.slice(0, slotCap);
          var isos = (m.showtimeStartsIso || []).slice(0, slotCap);
          var isoForAttr = [];
          for (var ai = 0; ai < isos.length; ai++) {
            if (isos[ai]) isoForAttr.push(String(isos[ai]));
          }
          if (isoForAttr.length) {
            initialSlotsAttr =
              ' data-ns-initial-slots="' +
              encodeURIComponent(JSON.stringify(isoForAttr)) +
              '"';
          }
          showtimeMarkupUnder =
            '<div class="showtimes showtimes--under-logo"></div>';
          showtimeMarkupFuture =
            '<div class="showtimes showtimes--future">' +
            buildFutureShowtimesFromTimesAndIsos(times, isos) +
            "</div>";
        }

        var metaParts = [];
        if (pills.length) metaParts.push('<div class="pill-row">' + pills.join("") + "</div>");
        if (castPills.length) metaParts.push('<div class="pill-row">' + castPills.join("") + "</div>");
        if (showtimeMarkupFuture) metaParts.push(showtimeMarkupFuture);
        var hasMeta = metaParts.length > 0;
        var metaColumn = hasMeta
          ? '<div class="movie-meta-column">' + metaParts.join("") + "</div>"
          : "";

        var plot = (m.plot || "").trim();
        var tickerMarkup = "";
        if (plot) {
          var sep = " · ";
          var dup = esc(plot) + sep;
          var durSec = Math.min(100, Math.max(22, 16 + plot.length / 4));
          var buf = '<span class="movie-ticker-buffer"></span>';
          tickerMarkup =
            '<div class="movie-ticker" style="--ticker-duration:' + durSec + 's" aria-hidden="true">' +
            '<div class="movie-ticker-track">' +
            buf +
            '<span class="movie-ticker-text">' +
            dup +
            "</span>" +
            buf +
            '<span class="movie-ticker-text">' +
            dup +
            "</span>" +
            "</div></div>";
        }

        var liveBadge = m.isNowPlaying
          ? '<div class="now-showing-live-badge" aria-hidden="true">Now playing</div>'
          : "";
        var overlayCls =
          "movie-overlay" + (m.isNowPlaying ? " movie-overlay--has-live-badge" : "");
        return (
          '<article class="movie-card' +
          (plot ? " movie-card--ticker" : "") +
          (m.isNowPlaying ? " movie-card--now-playing" : "") +
          '" data-ns-key="' +
          esc(nsKey) +
          '" data-ns-showtime-mode="' +
          esc(m.showtimeMode === "manual" ? "manual" : "auto") +
          '" data-runtime-mins="' +
          String(m.runtimeMins != null ? m.runtimeMins : 120) +
          '"' +
          initialSlotsAttr +
          ">" +
          '<div class="movie-banner" style="background-image:url(' + JSON.stringify(m.banner).slice(1, -1) + ')"></div>' +
          '<div class="' + overlayCls + '">' +
            liveBadge +
            '<div class="movie-overlay-row' + (hasMeta ? "" : " movie-overlay-row--solo") + '">' +
              '<div class="movie-logo-stack">' +
              '<div class="movie-logo' + (m.logo ? "" : " movie-logo--text") + '">' +
              (m.logo
                ? '<img src="' + esc(m.logo) + '" alt="' + esc(m.title) + '">'
                : esc(m.title)) +
              "</div>" +
              priceMarkupUnder +
              showtimeMarkupUnder +
              "</div>" +
              metaColumn +
            "</div>" +
          "</div>" +
          tickerMarkup +
          "</article>"
        );
      }

      function measureSegmentHeight() {
        var seg1 = loopWrap.querySelector(".ns-loop-segment");
        if (!seg1) {
          segmentHeightPx = 0;
          return;
        }
        segmentHeightPx = seg1.offsetHeight;
      }

      function disconnectSegObserver() {
        if (segResizeObs) {
          try {
            segResizeObs.disconnect();
          } catch (e) {}
          segResizeObs = null;
        }
      }

      function disconnectTickerObserver() {
        for (var ti = 0; ti < tickerObservers.length; ti++) {
          try {
            tickerObservers[ti].disconnect();
          } catch (e) {}
        }
        tickerObservers = [];
      }

      function resetTickerToStart(track) {
        track.classList.remove("movie-ticker-track--running");
        void track.offsetWidth;
        track.classList.add("movie-ticker-track--running");
      }

      function stopTickerTrack(track) {
        track.classList.remove("movie-ticker-track--running");
      }

      function extendAutoSlotsForNow(slotsMs, nowMs, runtimeMs, spacingMs) {
        var guard = 0;
        while (guard++ < 320) {
          if (findCurrentShowtimeIndex(slotsMs, nowMs, runtimeMs) >= 0) return;
          if (!slotsMs.length) return;
          if (nowMs < slotsMs[0]) return;
          var last = slotsMs[slotsMs.length - 1];
          if (last + runtimeMs <= nowMs) {
            slotsMs.push(last + spacingMs);
            continue;
          }
          return;
        }
      }

      /**
       * Past + current are extra; maxFuture is settings "showtimes per title" (upcoming only).
       * Auto: appends new starts (runtime + 10 min, same as server) so the window rolls forward.
       */
      function buildScheduleRows(mode, slotsMs, nowMs, runtimeMs, spacingMs, maxFuture) {
        var rows = [];
        if (!slotsMs.length) return rows;
        if (mode === "auto") {
          extendAutoSlotsForNow(slotsMs, nowMs, runtimeMs, spacingMs);
        }
        var curIdx = findCurrentShowtimeIndex(slotsMs, nowMs, runtimeMs);
        if (curIdx >= 0) {
          if (curIdx > 0) rows.push({ t: slotsMs[curIdx - 1], kind: "past" });
          rows.push({ t: slotsMs[curIdx], kind: "current" });
          var j = curIdx + 1;
          var fut = 0;
          while (fut < maxFuture) {
            if (mode === "manual" && j >= slotsMs.length) break;
            while (mode === "auto" && j >= slotsMs.length) {
              var lst = slotsMs[slotsMs.length - 1];
              slotsMs.push(lst + spacingMs);
            }
            rows.push({ t: slotsMs[j], kind: "future" });
            fut++;
            j++;
          }
          return rows;
        }
        if (nowMs < slotsMs[0]) {
          for (var f = 0; f < slotsMs.length && f < maxFuture; f++) {
            rows.push({ t: slotsMs[f], kind: "future" });
          }
          return rows;
        }
        var lastPast = -1;
        for (var i = 0; i < slotsMs.length; i++) {
          if (slotsMs[i] + runtimeMs <= nowMs) lastPast = i;
        }
        if (lastPast < 0) return rows;
        rows.push({ t: slotsMs[lastPast], kind: "past" });
        var j2 = lastPast + 1;
        while (mode === "auto" && j2 >= slotsMs.length) {
          slotsMs.push(slotsMs[slotsMs.length - 1] + spacingMs);
        }
        if (j2 < slotsMs.length) {
          var stNext = slotsMs[j2];
          if (nowMs >= stNext && nowMs < stNext + runtimeMs) {
            rows.push({ t: stNext, kind: "current" });
            j2++;
          }
        }
        var futG = 0;
        while (futG < maxFuture) {
          if (mode === "manual" && j2 >= slotsMs.length) break;
          while (mode === "auto" && j2 >= slotsMs.length) {
            slotsMs.push(slotsMs[slotsMs.length - 1] + spacingMs);
          }
          var st = slotsMs[j2];
          if (nowMs >= st && nowMs < st + runtimeMs) {
            rows.push({ t: st, kind: "current" });
            j2++;
            continue;
          }
          if (st + runtimeMs <= nowMs) {
            j2++;
            continue;
          }
          rows.push({ t: st, kind: "future" });
          futG++;
          j2++;
        }
        return rows;
      }

      function updateShowtimeScheduleHighlights(root) {
        if (!root) return;
        var nowMs = Date.now();
        var futureCap = Math.max(1, Math.min(6, showtimeDisplayMax || 6));
        var cards = root.querySelectorAll(".movie-card[data-ns-key][data-runtime-mins]");
        var buckets = {};
        for (var ci = 0; ci < cards.length; ci++) {
          var c = cards[ci];
          var k = c.getAttribute("data-ns-key");
          if (!k) continue;
          if (!buckets[k]) buckets[k] = [];
          buckets[k].push(c);
        }
        for (var key in buckets) {
          if (!Object.prototype.hasOwnProperty.call(buckets, key)) continue;
          var group = buckets[key];
          var rep = group[0];
          var run = parseInt(rep.getAttribute("data-runtime-mins") || "120", 10);
          if (!run || run < 1 || isNaN(run)) run = 120;
          var runtimeMs = run * 60000;
          var spacingMs = (run + 10) * 60000;
          var mode =
            rep.getAttribute("data-ns-showtime-mode") === "manual"
              ? "manual"
              : "auto";

          var state = showtimeSlotStateByKey[key];
          if (!state) {
            state = { slotsMs: [] };
            showtimeSlotStateByKey[key] = state;
          }
          if (!state.slotsMs.length) {
            var rawMs = [];
            var slotAttr = rep.getAttribute("data-ns-initial-slots");
            if (slotAttr) {
              try {
                var parsedIsos = JSON.parse(decodeURIComponent(slotAttr));
                if (Array.isArray(parsedIsos)) {
                  for (var si = 0; si < parsedIsos.length; si++) {
                    var msA = Date.parse(String(parsedIsos[si]));
                    if (!isNaN(msA)) rawMs.push(msA);
                  }
                }
              } catch (eAttr) {
                rawMs = [];
              }
            }
            if (!rawMs.length) {
              var initPills = rep.querySelectorAll(".showtime-pill[data-st-iso]");
              for (var pi = 0; pi < initPills.length; pi++) {
                var iso = initPills[pi].getAttribute("data-st-iso");
                if (!iso) continue;
                var ms = Date.parse(iso);
                if (!isNaN(ms)) rawMs.push(ms);
              }
            }
            state.slotsMs = normalizeSlotStartsMs(rawMs);
          }
          var slotsMs = state.slotsMs;
          if (!slotsMs.length) continue;

          var rows = buildScheduleRows(
            mode,
            slotsMs,
            nowMs,
            runtimeMs,
            spacingMs,
            futureCap
          );
          if (mode === "auto" && slotsMs.length > 72) {
            while (
              slotsMs.length > 56 &&
              slotsMs[0] + runtimeMs < nowMs - 6 * spacingMs
            ) {
              slotsMs.shift();
            }
          }
          var underInner = "";
          var futureMs = [];
          for (var ri = 0; ri < rows.length; ri++) {
            var row = rows[ri];
            var pill = showtimePillMarkup(row.t, row.kind);
            if (row.kind === "past" || row.kind === "current") underInner += pill;
            else if (row.kind === "future") futureMs.push(row.t);
          }
          var futureInner = buildFutureShowtimesRowedHtml(futureMs);
          var anyCur = false;
          for (var rj = 0; rj < rows.length; rj++) {
            if (rows[rj].kind === "current") {
              anyCur = true;
              break;
            }
          }
          for (var gi = 0; gi < group.length; gi++) {
            var card = group[gi];
            var underEl = card.querySelector(".showtimes--under-logo");
            var futEl = card.querySelector(".showtimes--future");
            if (underEl) underEl.innerHTML = underInner;
            if (futEl) futEl.innerHTML = futureInner;
            if (!underEl && !futEl) {
              var legacy = card.querySelector(".showtimes");
              if (legacy) legacy.innerHTML = underInner + futureInner;
            }
            card.classList.toggle("movie-card--schedule-active", anyCur);
          }
        }
      }

      function startScheduleHighlightTimer() {
        if (scheduleHighlightTimer) clearInterval(scheduleHighlightTimer);
        scheduleHighlightTimer = setInterval(function () {
          if (loopWrap && !loopWrap.hasAttribute("hidden")) {
            updateShowtimeScheduleHighlights(loopWrap);
          }
        }, 1000);
      }

      function stopScheduleHighlightTimer() {
        if (scheduleHighlightTimer) {
          clearInterval(scheduleHighlightTimer);
          scheduleHighlightTimer = null;
        }
      }

      function wireViewportTickers(root) {
        disconnectTickerObserver();
        if (reduceMotion) return;
        var cards = root.querySelectorAll(".movie-card--ticker");
        if (!cards.length) return;
        if (typeof IntersectionObserver === "undefined") {
          for (var i = 0; i < cards.length; i++) {
            var tr = cards[i].querySelector(".movie-ticker-track");
            if (tr) tr.classList.add("movie-ticker-track--running");
          }
          return;
        }
        /**
         * Use the scrolling list (#movieList) as the intersection root — not the
         * viewport. Cards on screen usually sit in the upper/middle window (below
         * the header), so a “bottom third of viewport” root almost never overlapped
         * them and the marquee never started.
         */
        var scrollRoot = listEl && listEl.nodeType === 1 ? listEl : null;
        var obsTicker = new IntersectionObserver(
          function (entries) {
            for (var j = 0; j < entries.length; j++) {
              var e = entries[j];
              var card = e.target;
              var track = card.querySelector(".movie-ticker-track");
              if (!track) continue;
              if (e.isIntersecting) {
                if (card.getAttribute("data-ns-ticker-armed") !== "1") {
                  card.setAttribute("data-ns-ticker-armed", "1");
                  resetTickerToStart(track);
                }
              } else {
                card.removeAttribute("data-ns-ticker-armed");
                stopTickerTrack(track);
              }
            }
          },
          {
            root: scrollRoot,
            rootMargin: "0px",
            threshold: 0.02,
          }
        );
        tickerObservers = [obsTicker];
        for (var k = 0; k < cards.length; k++) {
          obsTicker.observe(cards[k]);
        }
      }

      function watchSegmentHeight() {
        disconnectSegObserver();
        var seg1 = loopWrap.querySelector(".ns-loop-segment");
        if (!seg1 || typeof ResizeObserver === "undefined") {
          requestAnimationFrame(function () {
            measureSegmentHeight();
          });
          return;
        }
        segResizeObs = new ResizeObserver(function () {
          measureSegmentHeight();
        });
        segResizeObs.observe(seg1);
        requestAnimationFrame(function () {
          measureSegmentHeight();
        });
      }

      function fillSeamlessLoop(pool) {
        disconnectSegObserver();
        showtimeSlotStateByKey = {};
        var html = pool.map(function (m) { return buildMovieCardHtml(m); }).join("");
        loopWrap.innerHTML =
          '<div class="ns-loop-segment">' + html + "</div>" +
          '<div class="ns-loop-segment" aria-hidden="true">' + html + "</div>";
        loopWrap.removeAttribute("hidden");
        listEl.querySelectorAll(".muted-empty").forEach(function (n) { n.remove(); });
        requestAnimationFrame(function ensureScrollRoom() {
          var seg1 = loopWrap.querySelector(".ns-loop-segment");
          if (!seg1) return;
          var h = seg1.offsetHeight;
          var ch = listEl.clientHeight || 0;
          var target = h + Math.max(ch, Math.min(h, 400));
          var guard = 0;
          while (
            loopWrap.scrollHeight < target + 24 &&
            loopWrap.querySelectorAll(".ns-loop-segment").length < 8 &&
            guard++ < 6
          ) {
            var d = document.createElement("div");
            d.className = "ns-loop-segment";
            d.setAttribute("aria-hidden", "true");
            d.innerHTML = seg1.innerHTML;
            loopWrap.appendChild(d);
          }
          watchSegmentHeight();
          wireViewportTickers(loopWrap);
          updateShowtimeScheduleHighlights(loopWrap);
          startScheduleHighlightTimer();
        });
      }

      function applyNowPlayingOnly(rawCards) {
        var mapped = cardsToMovies(rawCards);
        var want = {};
        mapped.forEach(function (m) {
          want[stableNsKey(m)] = !!m.isNowPlaying;
        });
        loopWrap.querySelectorAll(".movie-card[data-ns-key]").forEach(function (card) {
          var k = card.getAttribute("data-ns-key");
          var on = !!want[k];
          card.classList.toggle("movie-card--now-playing", on);
          var overlay = card.querySelector(".movie-overlay");
          if (overlay) {
            overlay.classList.toggle("movie-overlay--has-live-badge", on);
          }
          var badge = card.querySelector(".now-showing-live-badge");
          if (on && !badge) {
            var d = document.createElement("div");
            d.className = "now-showing-live-badge";
            d.setAttribute("aria-hidden", "true");
            d.textContent = "Now playing";
            if (overlay) overlay.insertBefore(d, overlay.firstChild);
          } else if (!on && badge) {
            badge.remove();
          }
        });
        updateShowtimeScheduleHighlights(loopWrap);
      }

      function startAutoScroll() {
        if (autoScrollTimer) clearInterval(autoScrollTimer);
        if (reduceMotion) return;
        autoScrollTimer = setInterval(function () {
          var h = segmentHeightPx;
          if (h < 8) return;
          if (listEl.scrollHeight <= listEl.clientHeight) return;
          listEl.scrollTop += 1;
          if (listEl.scrollTop >= h - 0.5) {
            listEl.scrollTop -= h;
          }
        }, 35);
      }

      function renderEmpty(msg) {
        if (autoScrollTimer) clearInterval(autoScrollTimer);
        stopScheduleHighlightTimer();
        disconnectSegObserver();
        disconnectTickerObserver();
        showtimeSlotStateByKey = {};
        lastStructSig = null;
        lastPlayingSig = null;
        loopWrap.setAttribute("hidden", "");
        loopWrap.innerHTML = "";
        var empty = listEl.querySelector(".muted-empty");
        if (!empty) {
          empty = document.createElement("div");
          empty.className = "muted-empty";
          listEl.appendChild(empty);
        }
        empty.textContent = msg;
      }

      function loadMovies() {
        fetch(cardsUrl, {
          credentials: "same-origin",
          cache: "no-store",
        })
          .then(function (r) { return r.json(); })
          .then(function (payload) {
            var nextSettingsVersion =
              payload && payload.settingsVersion != null
                ? String(payload.settingsVersion)
                : settingsVersion;
            if (nextSettingsVersion !== settingsVersion) {
              window.location.reload();
              return;
            }
            var cards = payload && payload.movies ? payload.movies : [];
            var cw = payload && payload.curatedWeight != null ? parseInt(payload.curatedWeight, 10) : 4;
            curatedWeight = isNaN(cw) || cw < 1 ? 4 : Math.min(20, cw);
            showPricesEnabled = !!(payload && payload.showPrices === true);
            currencySymbol =
              payload && payload.currencySymbol != null
                ? String(payload.currencySymbol)
                : "$";
            var sdc =
              payload && payload.showtimeDisplayCount != null
                ? parseInt(payload.showtimeDisplayCount, 10)
                : 8;
            showtimeDisplayMax = isNaN(sdc) ? 6 : Math.max(1, Math.min(6, sdc));
            var struct =
              structSigFromCards(cards) + "|sdc:" + String(showtimeDisplayMax);
            var playing = JSON.stringify(
              cards.map(function (c) {
                return [stableNsKeyFromRaw(c), !!c.isNowPlaying];
              })
            );

            if (lastStructSig != null && struct === lastStructSig && playing !== lastPlayingSig) {
              lastPlayingSig = playing;
              applyNowPlayingOnly(cards);
              return;
            }
            if (lastStructSig != null && struct === lastStructSig && playing === lastPlayingSig) {
              return;
            }

            lastStructSig = struct;
            lastPlayingSig = playing;
            sourceMovies = cardsToMovies(cards);

            var emptyNode = listEl.querySelector(".muted-empty");
            if (emptyNode) emptyNode.remove();

            if (!sourceMovies.length) {
              renderEmpty("No movie cards are available yet.");
              return;
            }

            var pool = weightedShufflePool(sourceMovies, curatedWeight);
            if (pool.length > MAX_LOOP_CARDS) {
              pool = pool.slice(0, MAX_LOOP_CARDS);
            }

            listEl.scrollTop = 0;
            fillSeamlessLoop(pool);
            startAutoScroll();
          })
          .catch(function () {
            renderEmpty("Could not load movies.");
          });
      }

      var nsResizeTimer = null;
      window.addEventListener(
        "resize",
        function () {
          if (nsResizeTimer) clearTimeout(nsResizeTimer);
          nsResizeTimer = setTimeout(function () {
            measureSegmentHeight();
          }, 120);
        },
        { passive: true }
      );

      function tickTopClock() {
        var el = document.getElementById("nsTopClock");
        if (!el) return;
        var d = new Date();
        el.textContent = d.toLocaleTimeString([], {
          hour: "numeric",
          minute: "2-digit",
          second: "2-digit",
        });
        try {
          el.setAttribute("datetime", d.toISOString());
        } catch (err) {}
      }
      tickTopClock();
      setInterval(tickTopClock, 1000);

      loadMovies();
      setInterval(loadMovies, 15000);
    })();
  </script>
  <%- include('posterr-view-hotkeys.ejs', { baseUrl, viewHotkeysContext, viewHotkeysEnabled }) %>
</body>
</html>

<% if (typeof showNewFeaturesBanner !== 'undefined' && showNewFeaturesBanner) { %>
<div class="posterr-new-features-banner" role="status" style="flex-shrink:0;background:#c0392b;border-bottom:2px solid #922b21;color:#fff;font-weight:600;text-align:center;padding:0.5rem 0.75rem;width:100%;box-sizing:border-box;">
  New features have been added (v<%= typeof appVersion !== 'undefined' ? appVersion : '' %>). Open <a href="<%= baseUrl %>/settings" style="color:#fff;text-decoration:underline;font-weight:700;">Settings</a> and click &ldquo;Acknowledge there are new features&rdquo; to dismiss until the next version.
</div>
<% } %>

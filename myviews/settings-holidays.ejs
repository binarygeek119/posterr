<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta http-equiv="Cache-control" content="public">
  <title>PosterX - Holidays Settings</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
</head>
<body>
  <%if(!user.valid){%><script language='javascript'>
    window.location.href = '<%=baseUrl%>/logon';
  </script><%}%>
  <%- include('new-features-banner.ejs') %>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">PosterX</a></li>
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/settings">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Holidays</li>
      </ol>
    </nav>
    <div class="row gutters-sm">
      <div class="col-md-4 d-none d-md-block">
        <div class="card"><div class="card-body">
          <nav class="nav flex-column nav-pills nav-gap-y-1">
            <a href="<%=baseUrl%>/settings" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-cog"></i><span class="menu">Settings</span></a>
            <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-sync"></i><span class="menu">Sync</span></a>
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-film"></i><span class="menu">Now Showing</span></a>
            <a href="<%=baseUrl%>/settings/ads" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-bullhorn"></i><span class="menu">Ads</span></a>
            <a href="<%=baseUrl%>/settings/holidays" class="nav-item nav-link has-icon nav-link-faded active"><i class="fal fa-snowflake"></i><span class="menu">Holidays</span></a>
            <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-key"></i><span class="menu">TMDB API</span></a>
            <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-database"></i><span class="menu">Cache</span></a>
            <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-debug"></i><span class="menu">Debug</span></a>
            <a href="<%=baseUrl%>/settings#about" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-person-sign"></i><span class="menu">About</span></a>
          </nav>
        </div></div>
      </div>
      <div class="col-md-8">
        <div class="card">
          <div class="card-header border-bottom mb-3 d-flex d-md-none">
            <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
              <li class="nav-item"><a href="<%=baseUrl%>/settings" class="nav-link has-icon"><i class="fal fa-cog"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon"><i class="fal fa-sync"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon"><i class="fal fa-database"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon"><i class="fal fa-film"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon"><i class="fal fa-bullhorn"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/holidays" class="nav-link has-icon active"><i class="fal fa-snowflake"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/tmdb-api" class="nav-link has-icon"><i class="fal fa-key"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i></a></li>
              <li class="nav-item ml-auto"><a href="<%=baseUrl%>/settings#about" class="nav-link has-icon"><i class="fal fa-person-sign"></i></a></li>
            </ul>
          </div>
          <div class="card-body">
            <h4 class="mb-3">Holidays</h4>
            <% if (typeof holidayNotice !== "undefined" && holidayNotice && holidayNotice.text) { %>
              <div class="alert alert-<%= holidayNotice.ok ? "success" : "danger" %>"><%= holidayNotice.text %></div>
            <% } %>
            <% var _holidayRules = Array.isArray(holidayRules) ? holidayRules : []; %>
            <form method="post" action="<%=baseUrl%>/settings/holidays">
              <p class="text-muted mb-2">Add seasonal rules and match by tag, title keywords, and/or plot keywords. When a rule is active, media that matches the rule appears more often on Home and <code>/now-showing</code>.</p>
              <small class="form-text text-muted mb-3">Supports fixed ranges (month/day only) and dynamic dates (example: 4th Thursday in November for Thanksgiving).</small>
              <div id="holidayRulesWrap">
                <% if (_holidayRules.length) { %>
                  <% _holidayRules.forEach(function (r) { %>
                    <% var _mode = String(r && r.mode || "fixed").toLowerCase() === "dynamic" ? "dynamic" : "fixed"; %>
                    <div class="border rounded p-2 mb-2 holiday-rule-row">
                      <div class="form-row align-items-end">
                      <div class="col-md-3 mb-2">
                        <label class="small mb-1">Rule type</label>
                        <select class="form-control form-control-sm js-holiday-mode" name="holidayMode">
                          <option value="fixed" <%= _mode === "fixed" ? "selected" : "" %>>Fixed range</option>
                          <option value="dynamic" <%= _mode === "dynamic" ? "selected" : "" %>>Dynamic date</option>
                        </select>
                      </div>
                      <div class="col-md-3 mb-2 js-fixed-field">
                        <label class="small mb-1">Start date (year ignored)</label>
                        <input type="date" class="form-control form-control-sm" name="holidayStart" value="<%= r.start ? ((new Date().getFullYear()) + '-' + String(r.start)) : '' %>">
                      </div>
                      <div class="col-md-3 mb-2 js-fixed-field">
                        <label class="small mb-1">End date (year ignored)</label>
                        <input type="date" class="form-control form-control-sm" name="holidayEnd" value="<%= r.end ? ((new Date().getFullYear()) + '-' + String(r.end)) : '' %>">
                      </div>
                      <div class="col-md-2 mb-2 js-dynamic-field">
                        <label class="small mb-1">Month</label>
                        <select class="form-control form-control-sm" name="holidayMonth">
                          <% for (var m = 1; m <= 12; m++) { %>
                            <option value="<%=m%>" <%= Number(r.month || 11) === m ? "selected" : "" %>><%=m%></option>
                          <% } %>
                        </select>
                      </div>
                      <div class="col-md-2 mb-2 js-dynamic-field">
                        <label class="small mb-1">Weekday</label>
                        <% var _wd = Number(r.weekday || 4); %>
                        <select class="form-control form-control-sm" name="holidayWeekday">
                          <option value="0" <%= _wd === 0 ? "selected" : "" %>>Sun</option>
                          <option value="1" <%= _wd === 1 ? "selected" : "" %>>Mon</option>
                          <option value="2" <%= _wd === 2 ? "selected" : "" %>>Tue</option>
                          <option value="3" <%= _wd === 3 ? "selected" : "" %>>Wed</option>
                          <option value="4" <%= _wd === 4 ? "selected" : "" %>>Thu</option>
                          <option value="5" <%= _wd === 5 ? "selected" : "" %>>Fri</option>
                          <option value="6" <%= _wd === 6 ? "selected" : "" %>>Sat</option>
                        </select>
                      </div>
                      <div class="col-md-2 mb-2 js-dynamic-field">
                        <label class="small mb-1">Occurrence</label>
                        <% var _nth = String(r.nth || "4"); %>
                        <select class="form-control form-control-sm" name="holidayNth">
                          <option value="1" <%= _nth === "1" ? "selected" : "" %>>1st</option>
                          <option value="2" <%= _nth === "2" ? "selected" : "" %>>2nd</option>
                          <option value="3" <%= _nth === "3" ? "selected" : "" %>>3rd</option>
                          <option value="4" <%= _nth === "4" ? "selected" : "" %>>4th</option>
                          <option value="5" <%= _nth === "5" ? "selected" : "" %>>5th</option>
                          <option value="last" <%= _nth === "last" ? "selected" : "" %>>Last</option>
                        </select>
                      </div>
                      <div class="col-md-2 mb-2 js-dynamic-field">
                        <label class="small mb-1">Span days</label>
                        <input type="number" class="form-control form-control-sm" name="holidaySpanDays" min="0" max="31" value="<%= Number(r.spanDays || 0) %>">
                      </div>
                      <div class="col-md-4 mb-2">
                        <label class="small mb-1">Tag contains</label>
                        <input type="text" class="form-control form-control-sm" name="holidayTag" value="<%= String(r.tag || "") %>" maxlength="80" placeholder="christmas, halloween, easter">
                      </div>
                      <div class="col-md-4 mb-2">
                        <label class="small mb-1">Plot keywords (comma separated)</label>
                        <input type="text" class="form-control form-control-sm" name="holidayPlotKeywords" value="<%= String(r.plotKeywords || "") %>" maxlength="240" placeholder="christmas, santa, reindeer">
                      </div>
                      <div class="col-md-4 mb-2">
                        <label class="small mb-1">Title keywords (comma separated)</label>
                        <input type="text" class="form-control form-control-sm" name="holidayTitleKeywords" value="<%= String(r.titleKeywords || "") %>" maxlength="240" placeholder="christmas, xmas, noel">
                      </div>
                      <div class="col-md-2 mb-2">
                        <% var _matchMode = String(r.matchMode || "or").toLowerCase() === "and" ? "and" : "or"; %>
                        <label class="small mb-1">Match mode</label>
                        <select class="form-control form-control-sm" name="holidayMatchMode">
                          <option value="or" <%= _matchMode === "or" ? "selected" : "" %>>Any (OR)</option>
                          <option value="and" <%= _matchMode === "and" ? "selected" : "" %>>All (AND)</option>
                        </select>
                      </div>
                      <div class="col-md-1 mb-2 text-right">
                        <button type="button" class="btn btn-sm btn-outline-danger js-remove-holiday-row">&times;</button>
                      </div>
                      </div>
                    </div>
                  <% }) %>
                <% } %>
              </div>
              <div class="d-flex align-items-center">
                <button id="addHolidayRuleBtn" type="button" class="btn btn-outline-primary mr-2">Add date rule</button>
                <button type="submit" class="btn btn-primary">Save holiday rules</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    (function () {
      var wrap = document.getElementById("holidayRulesWrap");
      var addBtn = document.getElementById("addHolidayRuleBtn");
      if (!wrap || !addBtn) return;

      function rowHtml() {
        return '' +
          '<div class="border rounded p-2 mb-2 holiday-rule-row">' +
            '<div class="form-row align-items-end">' +
            '<div class="col-md-3 mb-2">' +
              '<label class="small mb-1">Rule type</label>' +
              '<select class="form-control form-control-sm js-holiday-mode" name="holidayMode">' +
                '<option value="fixed" selected>Fixed range</option>' +
                '<option value="dynamic">Dynamic date</option>' +
              '</select>' +
            '</div>' +
            '<div class="col-md-3 mb-2 js-fixed-field">' +
              '<label class="small mb-1">Start date (year ignored)</label>' +
              '<input type="date" class="form-control form-control-sm" name="holidayStart">' +
            '</div>' +
            '<div class="col-md-3 mb-2 js-fixed-field">' +
              '<label class="small mb-1">End date (year ignored)</label>' +
              '<input type="date" class="form-control form-control-sm" name="holidayEnd">' +
            '</div>' +
            '<div class="col-md-2 mb-2 js-dynamic-field">' +
              '<label class="small mb-1">Month</label>' +
              '<select class="form-control form-control-sm" name="holidayMonth">' +
                '<option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option><option value="6">6</option>' +
                '<option value="7">7</option><option value="8">8</option><option value="9">9</option><option value="10">10</option><option value="11" selected>11</option><option value="12">12</option>' +
              '</select>' +
            '</div>' +
            '<div class="col-md-2 mb-2 js-dynamic-field">' +
              '<label class="small mb-1">Weekday</label>' +
              '<select class="form-control form-control-sm" name="holidayWeekday">' +
                '<option value="0">Sun</option><option value="1">Mon</option><option value="2">Tue</option><option value="3">Wed</option><option value="4" selected>Thu</option><option value="5">Fri</option><option value="6">Sat</option>' +
              '</select>' +
            '</div>' +
            '<div class="col-md-2 mb-2 js-dynamic-field">' +
              '<label class="small mb-1">Occurrence</label>' +
              '<select class="form-control form-control-sm" name="holidayNth">' +
                '<option value="1">1st</option><option value="2">2nd</option><option value="3">3rd</option><option value="4" selected>4th</option><option value="5">5th</option><option value="last">Last</option>' +
              '</select>' +
            '</div>' +
            '<div class="col-md-2 mb-2 js-dynamic-field">' +
              '<label class="small mb-1">Span days</label>' +
              '<input type="number" class="form-control form-control-sm" name="holidaySpanDays" min="0" max="31" value="0">' +
            '</div>' +
            '<div class="col-md-4 mb-2">' +
              '<label class="small mb-1">Tag contains</label>' +
              '<input type="text" class="form-control form-control-sm" name="holidayTag" maxlength="80" placeholder="christmas, halloween, easter">' +
            '</div>' +
            '<div class="col-md-4 mb-2">' +
              '<label class="small mb-1">Plot keywords (comma separated)</label>' +
              '<input type="text" class="form-control form-control-sm" name="holidayPlotKeywords" maxlength="240" placeholder="christmas, santa, reindeer">' +
            '</div>' +
            '<div class="col-md-4 mb-2">' +
              '<label class="small mb-1">Title keywords (comma separated)</label>' +
              '<input type="text" class="form-control form-control-sm" name="holidayTitleKeywords" maxlength="240" placeholder="christmas, xmas, noel">' +
            '</div>' +
            '<div class="col-md-2 mb-2">' +
              '<label class="small mb-1">Match mode</label>' +
              '<select class="form-control form-control-sm" name="holidayMatchMode">' +
                '<option value="or" selected>Any (OR)</option>' +
                '<option value="and">All (AND)</option>' +
              '</select>' +
            '</div>' +
            '<div class="col-md-1 mb-2 text-right">' +
              '<button type="button" class="btn btn-sm btn-outline-danger js-remove-holiday-row">&times;</button>' +
            '</div>' +
            '</div>' +
          '</div>';
      }

      function applyModeVisibility(row) {
        if (!row) return;
        var modeSel = row.querySelector(".js-holiday-mode");
        var mode = modeSel ? modeSel.value : "fixed";
        var fixed = row.querySelectorAll(".js-fixed-field");
        var dyn = row.querySelectorAll(".js-dynamic-field");
        for (var i = 0; i < fixed.length; i++) fixed[i].style.display = mode === "fixed" ? "" : "none";
        for (var j = 0; j < dyn.length; j++) dyn[j].style.display = mode === "dynamic" ? "" : "none";
      }

      addBtn.addEventListener("click", function () {
        var holder = document.createElement("div");
        holder.innerHTML = rowHtml();
        var row = holder.firstChild;
        wrap.appendChild(row);
        applyModeVisibility(row);
      });

      wrap.addEventListener("click", function (ev) {
        var btn = ev.target && ev.target.closest ? ev.target.closest(".js-remove-holiday-row") : null;
        if (!btn) return;
        var row = btn.closest(".holiday-rule-row");
        if (row) row.remove();
      });
      wrap.addEventListener("change", function (ev) {
        var el = ev.target;
        if (!el || !el.classList || !el.classList.contains("js-holiday-mode")) return;
        applyModeVisibility(el.closest(".holiday-rule-row"));
      });

      if (!wrap.querySelector(".holiday-rule-row")) {
        addBtn.click();
      }
      var existing = wrap.querySelectorAll(".holiday-rule-row");
      for (var i = 0; i < existing.length; i++) applyModeVisibility(existing[i]);
    })();
  </script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js" crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/font-awesome.min.css">
  <title>Posterr - ADS Settings</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
</head>
<body>
  <%if(!user.valid){%><script language='javascript'>window.location.href = '<%=baseUrl%>/logon';</script><%}%>
  <%- include('new-features-banner.ejs') %>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">Posterr</a></li>
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/settings">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">ADS</li>
      </ol>
    </nav>
    <div class="row gutters-sm">
      <div class="col-md-4 d-none d-md-block">
        <div class="card"><div class="card-body">
          <nav class="nav flex-column nav-pills nav-gap-y-1">
            <a href="<%=baseUrl%>/settings" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-cog"></i><span class="menu">Settings</span></a>
            <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-sync"></i><span class="menu">Sync</span></a>
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-film"></i><span class="menu">Now Showing</span></a>
            <a href="<%=baseUrl%>/settings/ads" class="nav-item nav-link has-icon nav-link-faded active"><i class="fal fa-bullhorn"></i><span class="menu">Ads</span></a>
            <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-key"></i><span class="menu">TMDB API</span></a>
            <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-database"></i><span class="menu">Cache</span></a>
            <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-debug"></i><span class="menu">Debug</span></a>
            <a href="<%=baseUrl%>/settings#about" class="nav-item nav-link has-icon nav-link-faded"><i class="fal fa-person-sign"></i><span class="menu">About</span></a>
          </nav>
        </div></div>
      </div>
      <div class="col-md-8">
        <div class="card">
          <div class="card-header border-bottom mb-3 d-flex d-md-none">
            <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
              <li class="nav-item"><a href="<%=baseUrl%>/settings" class="nav-link has-icon"><i class="fal fa-cog"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon"><i class="fal fa-sync"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon"><i class="fal fa-database"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon"><i class="fal fa-film"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon active"><i class="fal fa-bullhorn"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/settings/tmdb-api" class="nav-link has-icon"><i class="fal fa-key"></i></a></li>
              <li class="nav-item"><a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i></a></li>
              <li class="nav-item ml-auto"><a href="<%=baseUrl%>/settings#about" class="nav-link has-icon"><i class="fal fa-person-sign"></i></a></li>
            </ul>
          </div>
          <div class="card-body">
            <% if (typeof notice !== "undefined" && notice && notice.text) { %>
              <div class="alert alert-<%= notice.ok ? "success" : "danger" %>"><%= notice.text %></div>
            <% } %>
            <h4 class="mb-3">ADS settings</h4>
            <p class="text-muted small">Dedicated ADS configuration page. Upload and manage ad slides, including custom price lines.</p>
            <p class="small mb-3"><a href="<%=baseUrl%>/ads" target="_blank" rel="noopener">Open dedicated Ads view</a></p>
            <form method="post" action="<%=baseUrl%>/settings/ads" class="mb-4 pb-3 border-bottom">
              <div class="form-group">
                <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                  <input type="checkbox" class="custom-control-input" name="enableAds" id="enableAds" value="true" <%= settings.enableAds == 'true' ? 'checked' : '' %>>
                  <label class="custom-control-label" for="enableAds">Enabled</label>
                  <small id="enableAdsHelp" class="form-text text-muted">Turns ad slides on/off in the main rotation.</small>
                </div>
              </div>
              <div class="form-group">
                <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                  <input type="checkbox" class="custom-control-input" name="adsOnly" id="adsOnly" value="true" <%= settings.adsOnly == 'true' ? 'checked' : '' %>>
                  <label class="custom-control-label" for="adsOnly">Only show ads</label>
                  <small class="form-text text-muted">When enabled, the home poster rotation shows only ad slides (if any ads exist).</small>
                </div>
              </div>
              <div class="form-group">
                <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                  <input type="checkbox" class="custom-control-input" name="adsTitleOutline" id="adsTitleOutline" value="true" <%= settings.adsTitleOutline == 'true' ? 'checked' : '' %>>
                  <label class="custom-control-label" for="adsTitleOutline">Title outline on /ads</label>
                  <small class="form-text text-muted">Adds a dark stroke around the ad name on the dedicated <code>/ads</code> view so it stays readable on busy images.</small>
                </div>
              </div>
              <div class="form-group">
                <label for="adsEveryPosters">Show ad after this many posters</label>
                <input type="number" min="0" step="1" class="form-control" id="adsEveryPosters" name="adsEveryPosters" value="<%=settings.adsEveryPosters !== undefined ? settings.adsEveryPosters : 0%>">
                <small class="form-text text-muted">0 disables spacing. Example: 5 means one ad appears after every 5 poster slides.</small>
              </div>
              <div class="form-group">
                <label for="adsRotationSeconds">Seconds per ad on <code>/ads</code></label>
                <% var _adsRot = (settings.adsRotationSeconds !== undefined && settings.adsRotationSeconds !== null) ? parseInt(settings.adsRotationSeconds, 10) : 10; if (isNaN(_adsRot)) _adsRot = 10; _adsRot = Math.min(600, Math.max(3, _adsRot)); %>
                <input type="number" min="3" max="600" step="1" class="form-control" id="adsRotationSeconds" name="adsRotationSeconds" value="<%= _adsRot %>">
                <small class="form-text text-muted">How long each slide stays on the dedicated Ads page before advancing (3–600 seconds). Independent of the main poster slide duration.</small>
              </div>
              <div class="form-group">
                <label for="adsPageStaySeconds">Seconds on full <code>/ads</code> page before returning home</label>
                <% var _adsPageStay = (settings.adsPageStaySeconds !== undefined && settings.adsPageStaySeconds !== null) ? parseInt(settings.adsPageStaySeconds, 10) : 0; if (isNaN(_adsPageStay)) _adsPageStay = 0; if (_adsPageStay > 0) _adsPageStay = Math.min(86400, Math.max(30, _adsPageStay)); %>
                <input type="number" min="0" max="86400" step="1" class="form-control" id="adsPageStaySeconds" name="adsPageStaySeconds" value="<%= _adsPageStay %>">
                <small class="form-text text-muted">0 leaves the Ads page open until you navigate away. When set, the browser returns to the home posters (<code>/</code>) after this many seconds in total on <code>/ads</code> (30–86400 when non-zero). Separate from “seconds per ad,” which only advances the slideshow between slides.</small>
              </div>
              <div class="form-group">
                <label for="adsCurrencyCode">Global currency</label>
                <select class="custom-select my-1 mr-sm-2" name="adsCurrencyCode" id="adsCurrencyCode">
                  <% var _adsCurrencyCode = (typeof adsCurrencyCode !== 'undefined' && adsCurrencyCode) ? String(adsCurrencyCode).toUpperCase() : 'USD'; %>
                  <option value="USD" <%= _adsCurrencyCode === "USD" ? "selected" : "" %>>USD ($)</option>
                  <option value="EUR" <%= _adsCurrencyCode === "EUR" ? "selected" : "" %>>EUR (€)</option>
                  <option value="GBP" <%= _adsCurrencyCode === "GBP" ? "selected" : "" %>>GBP (£)</option>
                  <option value="CAD" <%= _adsCurrencyCode === "CAD" ? "selected" : "" %>>CAD (C$)</option>
                  <option value="AUD" <%= _adsCurrencyCode === "AUD" ? "selected" : "" %>>AUD (A$)</option>
                  <option value="NZD" <%= _adsCurrencyCode === "NZD" ? "selected" : "" %>>NZD (NZ$)</option>
                  <option value="JPY" <%= _adsCurrencyCode === "JPY" ? "selected" : "" %>>JPY (¥)</option>
                </select>
                <small class="form-text text-muted">Used globally for all ad price rows.</small>
              </div>
              <button type="submit" class="btn btn-primary">Save ADS settings</button>
            </form>
            <div class="mb-4 pb-3 border-bottom">
              <h6 class="text-muted text-uppercase small mb-2">Dedicated <code>/ads</code> background</h6>
              <p class="text-muted small mb-2">One full-page backdrop behind all slides on the dedicated Ads view only. Files are stored under <code>config/ads-view</code> and served at <code>/custom/ads-view/</code>.</p>
              <% var _adsGlobalBg = (settings.adsGlobalBackgroundPath && String(settings.adsGlobalBackgroundPath).trim().startsWith("/custom/ads-view/")) ? String(settings.adsGlobalBackgroundPath).trim() : ""; %>
              <% if (_adsGlobalBg) { %>
                <div class="mb-2">
                  <small class="text-muted d-block mb-1">Current</small>
                  <code class="small d-block mb-2"><%= _adsGlobalBg %></code>
                  <img src="<%= baseUrl %><%= _adsGlobalBg %>" alt="" class="img-fluid rounded border" style="max-height: 140px;">
                </div>
              <% } %>
              <form method="post" enctype="multipart/form-data" action="<%= baseUrl %>/settings/ads/global-background" class="mb-2">
                <div class="form-group mb-2">
                  <label for="adsGlobalBgFile">Upload background image</label>
                  <input type="file" class="form-control-file" id="adsGlobalBgFile" name="adsGlobalBgFile" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp">
                </div>
                <button type="submit" class="btn btn-outline-primary btn-sm">Set page background</button>
              </form>
              <% if (_adsGlobalBg) { %>
                <form method="post" action="<%= baseUrl %>/settings/ads/global-background/clear" onsubmit="return confirm('Remove the dedicated /ads page background image?');">
                  <button type="submit" class="btn btn-outline-secondary btn-sm">Clear page background</button>
                </form>
              <% } %>
            </div>
            <h6 class="text-muted text-uppercase small mb-2">Add new ad</h6>
            <div class="border rounded p-3 mb-4">
              <div class="form-group">
                <label for="newAdTitle">Ad name</label>
                <input type="text" class="form-control" id="newAdTitle" placeholder="Example: Summer Popcorn Deal">
              </div>
              <div class="form-group">
                <label for="newAdFile">Upload ad image</label>
                <input type="file" class="form-control-file" id="newAdFile" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp">
              </div>
              <div class="form-group">
                <label for="newAdBgFile">Upload background image (optional)</label>
                <input type="file" class="form-control-file" id="newAdBgFile" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp">
              </div>
              <div class="mb-2 d-flex align-items-center justify-content-between">
                <strong class="small">Price lines</strong>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="newAdAddPriceLine">Add price line</button>
              </div>
              <div id="newAdPriceLines"></div>
              <div class="mb-2 mt-3 d-flex align-items-center justify-content-between">
                <strong class="small">Price add-ons</strong>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="newAdAddAddonLine">Add add-on</button>
              </div>
              <small class="form-text text-muted d-block mb-2">Each add-on has a label and amount. On <code>/ads</code> and the main poster deck, add-ons use the same pill style as price lines (with a leading + on the amount).</small>
              <div id="newAdAddonLines"></div>
              <button type="button" class="btn btn-success btn-sm mt-2" id="createAdBtn">Create ad</button>
            </div>
            <h6 class="text-muted text-uppercase small mb-2">Saved ads</h6>
            <div id="adsItemsWrap">
              <% if (Array.isArray(adsItems) && adsItems.length) { %>
                <% adsItems.forEach(function (ad) { %>
                  <div class="border rounded p-3 mb-3 ad-item" data-ad-id="<%= ad.id %>">
                    <div class="form-group">
                      <label>Ad name</label>
                      <input type="text" class="form-control form-control-sm ad-title" value="<%= ad.title %>">
                    </div>
                    <div class="form-group">
                      <label>Replace ad image (optional)</label>
                      <input type="file" class="form-control-file ad-file" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp">
                      <% if (ad.mediaPath) { %>
                        <small class="form-text text-muted">Current file: <code><%= ad.mediaPath %></code></small>
                      <% } %>
                    </div>
                    <div class="form-group">
                      <label>Replace background image (optional)</label>
                      <input type="file" class="form-control-file ad-bg-file" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp">
                      <% if (ad.backgroundMediaPath) { %>
                        <small class="form-text text-muted">Current background: <code><%= ad.backgroundMediaPath %></code></small>
                      <% } %>
                    </div>
                    <div class="mb-2 d-flex align-items-center justify-content-between">
                      <strong class="small">Price lines</strong>
                      <button type="button" class="btn btn-outline-secondary btn-sm ad-add-price-line">Add price line</button>
                    </div>
                    <div class="ad-price-lines"></div>
                    <div class="mb-2 mt-3 d-flex align-items-center justify-content-between">
                      <strong class="small">Price add-ons</strong>
                      <button type="button" class="btn btn-outline-secondary btn-sm ad-add-addon-line">Add add-on</button>
                    </div>
                    <div class="ad-addon-lines"></div>
                    <div class="mt-2">
                      <button type="button" class="btn btn-primary btn-sm ad-save-btn">Save ad</button>
                      <button type="button" class="btn btn-outline-danger btn-sm ad-delete-btn">Delete ad</button>
                    </div>
                    <script type="application/json" class="ad-prices-seed"><%- JSON.stringify(ad.prices || []) %></script>
                    <script type="application/json" class="ad-addons-seed"><%- JSON.stringify(ad.addons || []) %></script>
                  </div>
                <% }); %>
              <% } else { %>
                <p class="text-muted small mb-0" id="adsEmptyState">No ads saved yet.</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    (function () {
      var baseUrl = <%- JSON.stringify(baseUrl) %>;
      var currencySymbol = <%- JSON.stringify(adsCurrencySymbol || "$") %>;

      function esc(v) {
        var d = document.createElement("div");
        d.textContent = v == null ? "" : String(v);
        return d.innerHTML;
      }

      /** Parse money from a text field (allows 4.20, 0, 0.00; avoids type=number stripping trailing zeros). */
      function parseAmountInput(raw) {
        var t = String(raw == null ? "" : raw).trim().replace(/,/g, "");
        if (t === "") return null;
        var normalized = t.replace(/[^\d.-]/g, "");
        if (normalized === "" || normalized === "." || normalized === "-") return null;
        var n = Number(normalized);
        if (!Number.isFinite(n) || n < 0) return null;
        return Math.round(n * 100) / 100;
      }

      function formatAmountInputValue(amount) {
        if (amount == null || amount === "") return "";
        var n = Number(amount);
        if (!Number.isFinite(n)) return "";
        return String(amount);
      }

      function makePriceRow(title, amount) {
        var wrap = document.createElement("div");
        wrap.className = "form-row align-items-end mb-2 ad-price-line";
        wrap.innerHTML =
          '<div class="col-md-6"><label class="small mb-1">Price title</label><input type="text" class="form-control form-control-sm ad-price-title" value="' + esc(title || "") + '"></div>' +
          '<div class="col-md-4"><label class="small mb-1">Amount</label><div class="input-group input-group-sm"><div class="input-group-prepend"><span class="input-group-text">' + esc(currencySymbol) + '</span></div><input type="text" inputmode="decimal" autocomplete="off" class="form-control ad-price-amount" placeholder="0.00" value="' + esc(formatAmountInputValue(amount)) + '"></div></div>' +
          '<div class="col-md-2"><button type="button" class="btn btn-outline-danger btn-sm ad-price-remove">Remove</button></div>';
        wrap.querySelector(".ad-price-remove").addEventListener("click", function () {
          wrap.remove();
        });
        return wrap;
      }

      function makeAddonRow(title, amount) {
        var wrap = document.createElement("div");
        wrap.className = "form-row align-items-end mb-2 ad-addon-line";
        wrap.innerHTML =
          '<div class="col-md-6"><label class="small mb-1">Add-on title</label><input type="text" class="form-control form-control-sm ad-addon-title" placeholder="e.g. Tax, Large" value="' + esc(title || "") + '"></div>' +
          '<div class="col-md-4"><label class="small mb-1">Amount</label><div class="input-group input-group-sm"><div class="input-group-prepend"><span class="input-group-text">' + esc(currencySymbol) + '</span></div><input type="text" inputmode="decimal" autocomplete="off" class="form-control ad-addon-amount" placeholder="0.00" value="' + esc(formatAmountInputValue(amount)) + '"></div></div>' +
          '<div class="col-md-2"><button type="button" class="btn btn-outline-danger btn-sm ad-addon-remove">Remove</button></div>';
        wrap.querySelector(".ad-addon-remove").addEventListener("click", function () {
          wrap.remove();
        });
        return wrap;
      }

      function collectPriceLines(container) {
        var out = [];
        var rows = container.querySelectorAll(".ad-price-line");
        rows.forEach(function (row, index) {
          var title = row.querySelector(".ad-price-title").value.trim();
          var amountRaw = row.querySelector(".ad-price-amount").value;
          var amount = parseAmountInput(amountRaw);
          if (!title && amount == null) return;
          out.push({
            title: title,
            amount: amount,
            sortOrder: index
          });
        });
        return out;
      }

      function collectAddonLines(container) {
        var out = [];
        var rows = container.querySelectorAll(".ad-addon-line");
        rows.forEach(function (row, index) {
          var title = row.querySelector(".ad-addon-title").value.trim();
          var amountRaw = row.querySelector(".ad-addon-amount").value;
          var amount = parseAmountInput(amountRaw);
          if (amount == null) return;
          out.push({
            title: title,
            amount: amount,
            sortOrder: index
          });
        });
        return out;
      }

      function postForm(url, formData) {
        return fetch(url, {
          method: "POST",
          credentials: "same-origin",
          body: formData
        }).then(function (r) { return r.json(); });
      }

      var newLines = document.getElementById("newAdPriceLines");
      var newAddonLines = document.getElementById("newAdAddonLines");
      var addNewLineBtn = document.getElementById("newAdAddPriceLine");
      if (addNewLineBtn) {
        addNewLineBtn.addEventListener("click", function () {
          newLines.appendChild(makePriceRow("", ""));
        });
      }
      var newAdAddAddonBtn = document.getElementById("newAdAddAddonLine");
      if (newAdAddAddonBtn && newAddonLines) {
        newAdAddAddonBtn.addEventListener("click", function () {
          newAddonLines.appendChild(makeAddonRow("", ""));
        });
      }

      document.querySelectorAll(".ad-item").forEach(function (item) {
        var lineWrap = item.querySelector(".ad-price-lines");
        var addonWrap = item.querySelector(".ad-addon-lines");
        var seedNode = item.querySelector(".ad-prices-seed");
        var addonSeedNode = item.querySelector(".ad-addons-seed");
        var seed = [];
        try {
          seed = JSON.parse(seedNode ? seedNode.textContent : "[]");
        } catch (e) {
          seed = [];
        }
        if (!Array.isArray(seed) || !seed.length) {
          lineWrap.appendChild(makePriceRow("", ""));
        } else {
          seed.forEach(function (line) {
            lineWrap.appendChild(makePriceRow(line.title, line.amount));
          });
        }
        var addonSeed = [];
        try {
          addonSeed = JSON.parse(addonSeedNode ? addonSeedNode.textContent : "[]");
        } catch (e) {
          addonSeed = [];
        }
        if (Array.isArray(addonSeed) && addonSeed.length) {
          addonSeed.forEach(function (row) {
            addonWrap.appendChild(makeAddonRow(row.title, row.amount));
          });
        }
        item.querySelector(".ad-add-price-line").addEventListener("click", function () {
          lineWrap.appendChild(makePriceRow("", ""));
        });
        item.querySelector(".ad-add-addon-line").addEventListener("click", function () {
          addonWrap.appendChild(makeAddonRow("", ""));
        });
        item.querySelector(".ad-save-btn").addEventListener("click", function () {
          var adId = item.getAttribute("data-ad-id");
          var fd = new FormData();
          fd.append("title", item.querySelector(".ad-title").value.trim());
          fd.append("pricesJson", JSON.stringify(collectPriceLines(lineWrap)));
          fd.append("addonsJson", JSON.stringify(collectAddonLines(addonWrap)));
          var fileInput = item.querySelector(".ad-file");
          var bgFileInput = item.querySelector(".ad-bg-file");
          if (fileInput && fileInput.files && fileInput.files.length) {
            fd.append("adMediaFile", fileInput.files[0]);
          }
          if (bgFileInput && bgFileInput.files && bgFileInput.files.length) {
            fd.append("adBackgroundFile", bgFileInput.files[0]);
          }
          postForm(baseUrl + "/settings/ads/item/" + encodeURIComponent(adId), fd)
            .then(function (r) {
              if (r.error) throw new Error(r.error);
              window.location.reload();
            })
            .catch(function (e) { alert(e.message || e); });
        });
        item.querySelector(".ad-delete-btn").addEventListener("click", function () {
          if (!confirm("Delete this ad?")) return;
          postForm(baseUrl + "/settings/ads/item/" + encodeURIComponent(item.getAttribute("data-ad-id")) + "/delete", new FormData())
            .then(function (r) {
              if (r.error) throw new Error(r.error);
              window.location.reload();
            })
            .catch(function (e) { alert(e.message || e); });
        });
      });

      var createBtn = document.getElementById("createAdBtn");
      if (createBtn) {
        createBtn.addEventListener("click", function () {
          var fileInput = document.getElementById("newAdFile");
          if (!fileInput || !fileInput.files || !fileInput.files.length) {
            alert("Please upload an ad image.");
            return;
          }
          var fd = new FormData();
          fd.append("title", document.getElementById("newAdTitle").value.trim());
          fd.append("adMediaFile", fileInput.files[0]);
          var bgNewInput = document.getElementById("newAdBgFile");
          if (bgNewInput && bgNewInput.files && bgNewInput.files.length) {
            fd.append("adBackgroundFile", bgNewInput.files[0]);
          }
          fd.append("pricesJson", JSON.stringify(collectPriceLines(newLines)));
          fd.append("addonsJson", JSON.stringify(collectAddonLines(newAddonLines)));
          postForm(baseUrl + "/settings/ads/item", fd)
            .then(function (r) {
              if (r.error) throw new Error(r.error);
              window.location.reload();
            })
            .catch(function (e) { alert(e.message || e); });
        });
      }
    })();
  </script>
</body>
</html>

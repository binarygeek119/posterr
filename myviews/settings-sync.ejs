<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/font-awesome.min.css">
  <title>Posterr — Sync</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
</head>
<body>
  <%if(!user.valid){%><script language='javascript'>
    window.location.href = '<%=baseUrl%>/logon';
  </script><%}%>
  <%- include('new-features-banner.ejs') %>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">Posterr</a></li>
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/settings">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Sync</li>
      </ol>
    </nav>
    <div class="row gutters-sm">
      <div class="col-md-4 d-none d-md-block">
        <div class="card">
          <div class="card-body">
            <nav class="nav flex-column nav-pills nav-gap-y-1">
              <a href="<%=baseUrl%>/settings" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-cog"></i><span class="menu">Settings</span>
              </a>
              <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded active">
                <i class="fal fa-sync"></i><span class="menu">Sync</span>
              </a>
              <a href="<%=baseUrl%>/settings/now-showing" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-film"></i><span class="menu">Now Showing</span>
              </a>
              <a href="<%=baseUrl%>/settings/ads" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-bullhorn"></i><span class="menu">Ads</span>
              </a>
              <a href="<%=baseUrl%>/settings/holidays" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-snowflake"></i><span class="menu">Holidays</span>
              </a>
              <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-key"></i><span class="menu">TMDB API</span>
              </a>
              <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-database"></i><span class="menu">Cache</span>
              </a>
              <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-debug"></i><span class="menu">Debug</span>
              </a>
              <a href="<%=baseUrl%>/settings#about" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-person-sign"></i><span class="menu">About</span>
              </a>
            </nav>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card">
          <div class="d-none d-md-flex border-bottom py-2 px-3 justify-content-end align-items-center flex-wrap">
            <a href="<%=baseUrl%>/settings#collapseFive" class="nav-link has-icon text-body py-1 mr-3"><i class="fal fa-play"></i><span class="menu">Now Playing</span></a>
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon text-body py-1"><i class="fal fa-film"></i><span class="menu">Now Showing settings</span></a>
          </div>
          <div class="card-header border-bottom mb-3 d-flex d-md-none">
            <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings" class="nav-link has-icon"><i class="fal fa-cog"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon active"><i class="fal fa-sync"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon"><i class="fal fa-database"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon"><i class="fal fa-film"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon"><i class="fal fa-bullhorn"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/holidays" class="nav-link has-icon"><i class="fal fa-snowflake"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings#collapseFive" class="nav-link has-icon"><i class="fal fa-play"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-link has-icon"><i class="fal fa-key"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i></a>
              </li>
              <li class="nav-item ml-auto">
                <a href="<%=baseUrl%>/settings#about" class="nav-link has-icon"><i class="fal fa-person-sign"></i></a>
              </li>
            </ul>
          </div>
          <div class="card-body">
            <% if (typeof syncNotice !== "undefined" && syncNotice && syncNotice.text) { %>
              <div class="alert alert-<%= syncNotice.ok ? "success" : "danger" %>" role="alert"><%= syncNotice.text %></div>
            <% } %>
            <div class="d-flex flex-wrap align-items-start justify-content-between mb-3">
              <h4 class="mb-0">Poster &amp; library sync</h4>
              <button type="button" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center flex-shrink-0 mt-2 mt-md-0 px-3" data-toggle="modal" data-target="#aboutSyncModal" aria-label="About poster and library sync">
                <i class="fal fa-info-circle mr-2" aria-hidden="true"></i><span>About sync</span>
              </button>
            </div>
            <p class="text-muted">Posterr can walk your configured on-demand libraries on Plex, Jellyfin, Emby, or Kodi and cache posters, backgrounds, banners, cast portraits, and related images into <code>config/cache/imagecache</code>, with metadata in <code>config/posterr-poster-metadata.db</code> (SQLite). Legacy data under <code>saved/</code> (JSON or SQLite) is migrated automatically on first start. After a sync, open <strong>Cache</strong> in the sidebar for a full <strong>cache status</strong> summary and per-type image counts.</p>

            <dl class="row small mb-4">
              <dt class="col-sm-5">Refresh poster DB (minutes)</dt>
              <dd class="col-sm-7"><%= settings.posterCacheRefreshMins != null ? settings.posterCacheRefreshMins : 0 %> <span class="text-muted">(0 = scheduled refresh off)</span></dd>
              <dt class="col-sm-5">Min. age before change checks</dt>
              <dd class="col-sm-7"><%= settings.posterCacheMinAgeBeforeChangeCheckMins != null ? settings.posterCacheMinAgeBeforeChangeCheckMins : 0 %> min</dd>
              <dt class="col-sm-5">Prefer cached poster library</dt>
              <dd class="col-sm-7"><%= settings.preferCachedPosters == 'true' ? 'On' : 'Off' %></dd>
              <dt class="col-sm-5">On-demand libraries</dt>
              <dd class="col-sm-7"><%= settings.onDemandLibraries ? settings.onDemandLibraries : '—' %></dd>
            </dl>

            <p class="mb-3">Change these values under <strong>Settings</strong> → <strong>MEDIA SERVER</strong> (poster cache section).</p>

            <div class="border rounded p-3 mb-4 bg-light">
              <h6 class="text-uppercase text-muted small mb-2">Sync status</h6>
              <p class="mb-2"><strong>Connected server type:</strong> <span id="syncServerType"><%= settings.mediaServerType ? settings.mediaServerType : 'plex' %></span></p>
              <div class="progress mb-2" style="height: 26px;">
                <div id="syncProgressBar" class="progress-bar bg-primary" role="progressbar" style="width: 0%;" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
              <p id="syncProgressDetail" class="small text-muted mb-2">Idle — start a sync to see progress.</p>
              <div id="syncLibrariesWrap" class="d-none">
                <h6 class="text-uppercase text-muted small mb-2">Per library</h6>
                <div id="syncLibrariesList" class="small"></div>
              </div>
            </div>

            <div class="d-flex flex-wrap align-items-center mb-3">
              <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-0 mr-2" id="syncTriggerForm" onsubmit="return confirm('Sync all configured on-demand libraries now? Large libraries may take several minutes.');">
                <button type="submit" class="btn btn-primary" id="syncStartBtn">Sync all libraries</button>
              </form>
              <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-0 mr-2" onsubmit="return confirm('Run metadata-only sync for all libraries? This skips image downloads and only updates poster metadata rows.');">
                <input type="hidden" name="syncMode" value="metadata" />
                <button type="submit" class="btn btn-outline-primary">Metadata-only (all)</button>
              </form>
              <form method="post" action="<%=baseUrl%>/settings/sync/abort" class="mb-0" id="syncAbortForm" onsubmit="return confirm('Abort the current library sync? Titles cached so far will be saved to the poster database.');">
                <button type="submit" class="btn btn-outline-danger" id="syncAbortBtn" disabled>Abort sync</button>
              </form>
            </div>
            <div class="d-flex flex-wrap align-items-center mb-4">
              <form method="post" action="<%=baseUrl%>/settings/sync/clear-cache" class="mb-0" id="syncClearCacheForm" onsubmit="return confirm('Clear all synced cache files and reset the poster metadata database? This cannot be undone.');">
                <button type="submit" class="btn btn-outline-danger" id="syncClearCacheBtn">Clear sync cache + database</button>
              </form>
              <small class="text-muted ml-0 ml-md-3 mt-2 mt-md-0">Removes files in <code>config/cache/imagecache</code> and resets <code>config/posterr-poster-metadata.db</code>.</small>
            </div>

            <% var libList = typeof onDemandLibraryList !== 'undefined' && onDemandLibraryList ? onDemandLibraryList : []; %>
            <% if (libList.length > 1) { %>
            <h6 class="text-uppercase text-muted small mb-2">Sync one library</h6>
            <p class="small text-muted mb-2">Run a full poster sync for a single library without touching the others.</p>
            <ul class="list-unstyled mb-3">
              <% libList.forEach(function (lib) { %>
              <li class="mb-2 d-flex flex-wrap align-items-center">
                <span class="mr-2 mb-1"><%= lib %></span>
                <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-0 d-inline" onsubmit="return confirm('Sync this library only? Large libraries may take several minutes.');">
                  <input type="hidden" name="library" value="<%= lib %>" />
                  <button type="submit" class="btn btn-sm btn-outline-primary sync-lib-btn">Sync this library</button>
                </form>
                <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-0 d-inline ml-2" onsubmit="return confirm('Run metadata-only sync for this library? Image downloads will be skipped.');">
                  <input type="hidden" name="library" value="<%= lib %>" />
                  <input type="hidden" name="syncMode" value="metadata" />
                  <button type="submit" class="btn btn-sm btn-outline-secondary">Metadata-only</button>
                </form>
              </li>
              <% }); %>
            </ul>
            <% } else if (libList.length === 1) { %>
            <h6 class="text-uppercase text-muted small mb-2">Single configured library</h6>
            <p class="small text-muted mb-2">You only have one on-demand library configured. Use <strong>Sync all libraries</strong> above, or sync it directly:</p>
            <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-3" onsubmit="return confirm('Sync this library? Large libraries may take several minutes.');">
              <input type="hidden" name="library" value="<%= libList[0] %>" />
              <button type="submit" class="btn btn-sm btn-outline-primary sync-lib-btn">Sync “<%= libList[0] %>”</button>
            </form>
            <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-3" onsubmit="return confirm('Run metadata-only sync for this library? Image downloads will be skipped.');">
              <input type="hidden" name="library" value="<%= libList[0] %>" />
              <input type="hidden" name="syncMode" value="metadata" />
              <button type="submit" class="btn btn-sm btn-outline-secondary">Metadata-only “<%= libList[0] %>”</button>
            </form>
            <% } %>

            <p class="small text-muted mb-0">Progress updates automatically while this page is open. You can leave and return; the server continues until finished. Details also appear in the Posterr console log.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="aboutSyncModal" tabindex="-1" role="dialog" aria-labelledby="aboutSyncModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="aboutSyncModalLabel">About poster &amp; library sync</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <p class="text-muted">Library sync downloads artwork and metadata from your media server so slides load quickly and work offline from the cache.</p>
          <h6 class="text-uppercase text-muted small mt-3 mb-2">What gets synced</h6>
          <ul class="small mb-3">
            <li>Libraries listed under <strong>On-demand libraries</strong> in <strong>Settings</strong> → <strong>MEDIA SERVER</strong> (same names as on this page).</li>
            <li>Posters and optional images depend on <strong>Download fan art / backgrounds</strong> and the per-type image options in that section (e.g. banners, logos, cast portraits).</li>
            <li>Files are stored under <code>config/cache/imagecache</code>. The poster index lives in <code>config/posterr-poster-metadata.db</code> (SQLite).</li>
          </ul>
          <h6 class="text-uppercase text-muted small mt-3 mb-2">Sync actions</h6>
          <ul class="small mb-3">
            <li><strong>Sync all libraries</strong> walks every configured on-demand library.</li>
            <li><strong>Sync this library</strong> (when you have more than one) updates only that library.</li>
            <li>Large libraries can take several minutes; the job keeps running if you close this page.</li>
          </ul>
          <h6 class="text-uppercase text-muted small mt-3 mb-2">Progress &amp; maintenance</h6>
          <ul class="small mb-3">
            <li>The progress bar polls the server while this page stays open.</li>
            <li><strong>Refresh poster DB</strong> and related poster-cache options are on the main <strong>Settings</strong> page (poster cache section).</li>
            <li>Use <strong>Cache</strong> in the sidebar after a sync to see counts, missing files, and cleanup tools.</li>
          </ul>
          <p class="small text-muted mb-0">Older poster data under <code>saved/</code> is migrated automatically the first time you run this version.</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var progressUrl = <%- JSON.stringify(baseUrl + "/settings/sync/progress") %>;
      var pollMs = 500;
      var bar = document.getElementById("syncProgressBar");
      var detail = document.getElementById("syncProgressDetail");
      var serverEl = document.getElementById("syncServerType");
      var startBtn = document.getElementById("syncStartBtn");
      var abortBtn = document.getElementById("syncAbortBtn");
      var clearBtn = document.getElementById("syncClearCacheBtn");
      var libWrap = document.getElementById("syncLibrariesWrap");
      var libList = document.getElementById("syncLibrariesList");

      function setLibButtonsDisabled(disabled) {
        var btns = document.querySelectorAll(".sync-lib-btn");
        for (var j = 0; j < btns.length; j++) {
          btns[j].disabled = !!disabled;
        }
      }

      function escapeHtml(s) {
        if (s == null) return "";
        return String(s)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function fetchLabel(fs) {
        if (fs === "skipped") return "skipped";
        if (fs === "loading") return "fetching…";
        if (fs === "done") return "listed";
        return "pending";
      }

      function cacheLabel(cs, cached, total, metadataOnlySync) {
        var runningWord = metadataOnlySync ? "syncing metadata " : "caching ";
        if (cs === "skipped") return "skipped";
        if (cs === "pending" && total === 0) return "—";
        if (cs === "pending") return "waiting (" + cached + " / " + total + ")";
        if (cs === "running") return runningWord + cached + " / " + total;
        if (cs === "done") return "done " + cached + " / " + total;
        return String(cs || "");
      }

      function renderLibraries(rows, metadataOnlySync) {
        if (!rows || !rows.length) {
          libWrap.classList.add("d-none");
          libList.innerHTML = "";
          return;
        }
        libWrap.classList.remove("d-none");
        var html = "";
        for (var i = 0; i < rows.length; i++) {
          var r = rows[i];
          var name = escapeHtml(r.name);
          var itemsFound = r.itemsFound != null ? r.itemsFound : 0;
          var ct = r.cacheTotal != null ? r.cacheTotal : 0;
          var cc = r.itemsCached != null ? r.itemsCached : 0;
          var fetchL = fetchLabel(r.fetchStatus);
          var cacheL = cacheLabel(r.cacheStatus, cc, ct, metadataOnlySync);
          var pct =
            ct > 0 ? Math.min(100, Math.round((cc / ct) * 100)) : r.cacheStatus === "done" ? 100 : 0;
          html +=
            '<div class="mb-3 pb-2 border-bottom border-light">' +
            '<div class="d-flex justify-content-between align-items-baseline flex-wrap">' +
            '<strong class="mr-2">' +
            name +
            "</strong>" +
            '<span class="text-muted">' +
            escapeHtml(fetchL) +
            " · " +
            itemsFound +
            " from server</span></div>" +
            '<div class="text-muted mb-1">' +
            escapeHtml(cacheL) +
            "</div>" +
            '<div class="progress" style="height: 8px;"><div class="progress-bar bg-info" role="progressbar" style="width: ' +
            pct +
            '%;"></div></div></div>';
        }
        libList.innerHTML = html;
      }

      function setBarMode(mode) {
        bar.classList.remove("bg-primary", "bg-success", "bg-danger", "progress-bar-striped", "progress-bar-animated");
        if (mode === "ok") bar.classList.add("bg-success");
        else if (mode === "err") bar.classList.add("bg-danger");
        else bar.classList.add("bg-primary");
      }

      function poll() {
        fetch(progressUrl, { credentials: "same-origin" })
          .then(function (r) {
            if (r.status === 401) {
              detail.textContent = "Session expired — refresh and sign in again.";
              return null;
            }
            return r.json();
          })
          .then(function (data) {
            if (!data) return;
            if (data.serverKind) {
              serverEl.textContent = data.serverKind;
            }
            if (data.status === "idle") {
              bar.style.width = "0%";
              bar.classList.remove("progress-bar-striped", "progress-bar-animated");
              setBarMode("primary");
              detail.textContent = "Idle — use the button below to start a sync.";
              renderLibraries([], false);
              startBtn.disabled = false;
              if (abortBtn) abortBtn.disabled = true;
              if (clearBtn) clearBtn.disabled = false;
              setLibButtonsDisabled(false);
              setTimeout(poll, pollMs * 2);
              return;
            }
            startBtn.disabled = data.status === "running";
            if (abortBtn) abortBtn.disabled = data.status !== "running";
            if (clearBtn) clearBtn.disabled = data.status === "running";
            setLibButtonsDisabled(data.status === "running");

            if (data.indeterminate) {
              bar.style.width = "100%";
              bar.classList.add("progress-bar-striped", "progress-bar-animated");
              setBarMode("primary");
              var indLab =
                data.syncScope === "single" && data.syncSingleLibrary
                  ? "Library: " + data.syncSingleLibrary + " — "
                  : "";
              detail.textContent =
                indLab + (data.label || "Working…");
              renderLibraries(data.libraries || [], data.metadataOnlySync === true);
              setTimeout(poll, pollMs);
              return;
            }

            var pct = data.percent != null ? data.percent : 0;
            bar.style.width = pct + "%";
            if (data.status === "running") {
              bar.classList.add("progress-bar-striped", "progress-bar-animated");
              setBarMode("primary");
            } else {
              bar.classList.remove("progress-bar-striped", "progress-bar-animated");
            }

            if (data.status === "error") {
              setBarMode("err");
              bar.style.width = "100%";
              detail.textContent = "Error: " + (data.error || "Unknown error");
              renderLibraries(data.libraries || [], data.metadataOnlySync === true);
            } else if (data.status === "done") {
              setBarMode("ok");
              bar.style.width = "100%";
              detail.textContent =
                (data.label || "Complete.") +
                (data.total > 0 ? " — " + data.total + " title(s) total." : "");
              renderLibraries(data.libraries || [], data.metadataOnlySync === true);
            } else {
              var scope =
                data.syncScope === "single" && data.syncSingleLibrary
                  ? "Library: " + data.syncSingleLibrary + " — "
                  : "";
              var line =
                scope +
                (data.label || "") +
                (data.total > 0
                  ? " — " + data.processed + " / " + data.total + " (" + pct + "% overall)"
                  : data.percent != null
                  ? " — " + pct + "% overall"
                  : "");
              detail.textContent = line || "Running…";
              renderLibraries(data.libraries || [], data.metadataOnlySync === true);
            }

            setTimeout(poll, pollMs);
          })
          .catch(function () {
            setTimeout(poll, pollMs * 3);
          });
      }

      setTimeout(poll, 300);
    })();
  </script>
</body>
</html>

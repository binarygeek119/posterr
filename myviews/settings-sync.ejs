<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/font-awesome.min.css">
  <title>Posterr — Sync</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
</head>
<body>
  <%if(!user.valid){%><script language='javascript'>
    window.location.href = '<%=baseUrl%>/logon';
  </script><%}%>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">Posterr</a></li>
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/settings">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Sync</li>
      </ol>
    </nav>
    <%if(typeof syncNotice !== 'undefined' && syncNotice && syncNotice.text && syncNotice.ok === false) {%><script>
      alert(<%- JSON.stringify(syncNotice.text) %>);
    </script><%}%>

    <div class="row gutters-sm">
      <div class="col-md-4 d-none d-md-block">
        <div class="card">
          <div class="card-body">
            <nav class="nav flex-column nav-pills nav-gap-y-1">
              <a href="<%=baseUrl%>/settings" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-cog"></i><span class="menu">Settings</span>
              </a>
              <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded active">
                <i class="fal fa-sync"></i><span class="menu">Sync</span>
              </a>
              <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-database"></i><span class="menu">Cache</span>
              </a>
              <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-debug"></i><span class="menu">Debug</span>
              </a>
              <a href="<%=baseUrl%>/settings#about" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-person-sign"></i><span class="menu">About</span>
              </a>
            </nav>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card">
          <div class="card-header border-bottom mb-3 d-flex d-md-none">
            <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings" class="nav-link has-icon"><i class="fal fa-cog"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon active"><i class="fal fa-sync"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon"><i class="fal fa-database"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i></a>
              </li>
              <li class="nav-item">
                <a href="<%=baseUrl%>/settings#about" class="nav-link has-icon"><i class="fal fa-person-sign"></i></a>
              </li>
            </ul>
          </div>
          <div class="card-body">
            <h4 class="mb-3">Poster &amp; library sync</h4>
            <p class="text-muted">Posterr can walk your configured on-demand libraries on Plex, Jellyfin, Emby, or Kodi and cache posters, fanart, and related images into <code>config/cache/imagecache</code>, with metadata in <code>config/cache/posterr-poster-metadata.db</code> (SQLite). Legacy data under <code>saved/</code> (JSON or SQLite) is migrated automatically on first start.</p>

            <dl class="row small mb-4">
              <dt class="col-sm-5">Refresh poster DB (minutes)</dt>
              <dd class="col-sm-7"><%= settings.posterCacheRefreshMins != null ? settings.posterCacheRefreshMins : 0 %> <span class="text-muted">(0 = scheduled refresh off)</span></dd>
              <dt class="col-sm-5">Min. age before change checks</dt>
              <dd class="col-sm-7"><%= settings.posterCacheMinAgeBeforeChangeCheckMins != null ? settings.posterCacheMinAgeBeforeChangeCheckMins : 0 %> min</dd>
              <dt class="col-sm-5">Prefer cached poster library</dt>
              <dd class="col-sm-7"><%= settings.preferCachedPosters == 'true' ? 'On' : 'Off' %></dd>
              <dt class="col-sm-5">On-demand libraries</dt>
              <dd class="col-sm-7"><%= settings.onDemandLibraries ? settings.onDemandLibraries : '—' %></dd>
            </dl>

            <p class="mb-3">Change these values under <strong>Settings</strong> → <strong>MEDIA SERVER</strong> (poster cache section).</p>

            <div class="border rounded p-3 mb-4 bg-light">
              <h6 class="text-uppercase text-muted small mb-2">Sync status</h6>
              <p class="mb-2"><strong>Connected server type:</strong> <span id="syncServerType"><%= settings.mediaServerType ? settings.mediaServerType : 'plex' %></span></p>
              <div class="progress mb-2" style="height: 26px;">
                <div id="syncProgressBar" class="progress-bar bg-primary" role="progressbar" style="width: 0%;" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
              <p id="syncProgressDetail" class="small text-muted mb-2">Idle — start a sync to see progress.</p>
              <div id="syncLibrariesWrap" class="d-none">
                <h6 class="text-uppercase text-muted small mb-2">Per library</h6>
                <div id="syncLibrariesList" class="small"></div>
              </div>
            </div>

            <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-3" id="syncTriggerForm" onsubmit="return confirm('Sync all configured on-demand libraries now? Large libraries may take several minutes.');">
              <button type="submit" class="btn btn-primary" id="syncStartBtn">Sync all libraries</button>
            </form>

            <% var libList = typeof onDemandLibraryList !== 'undefined' && onDemandLibraryList ? onDemandLibraryList : []; %>
            <% if (libList.length > 1) { %>
            <h6 class="text-uppercase text-muted small mb-2">Sync one library</h6>
            <p class="small text-muted mb-2">Run a full poster sync for a single library without touching the others.</p>
            <ul class="list-unstyled mb-3">
              <% libList.forEach(function (lib) { %>
              <li class="mb-2 d-flex flex-wrap align-items-center">
                <span class="mr-2 mb-1"><%= lib %></span>
                <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-0 d-inline" onsubmit="return confirm('Sync this library only? Large libraries may take several minutes.');">
                  <input type="hidden" name="library" value="<%= lib %>" />
                  <button type="submit" class="btn btn-sm btn-outline-primary sync-lib-btn">Sync this library</button>
                </form>
              </li>
              <% }); %>
            </ul>
            <% } else if (libList.length === 1) { %>
            <h6 class="text-uppercase text-muted small mb-2">Single configured library</h6>
            <p class="small text-muted mb-2">You only have one on-demand library configured. Use <strong>Sync all libraries</strong> above, or sync it directly:</p>
            <form method="post" action="<%=baseUrl%>/settings/sync/trigger" class="mb-3" onsubmit="return confirm('Sync this library? Large libraries may take several minutes.');">
              <input type="hidden" name="library" value="<%= libList[0] %>" />
              <button type="submit" class="btn btn-sm btn-outline-primary sync-lib-btn">Sync “<%= libList[0] %>”</button>
            </form>
            <% } %>

            <p class="small text-muted mb-0">Progress updates automatically while this page is open. You can leave and return; the server continues until finished. Details also appear in the Posterr console log.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    (function () {
      var progressUrl = <%- JSON.stringify(baseUrl + "/settings/sync/progress") %>;
      var pollMs = 500;
      var bar = document.getElementById("syncProgressBar");
      var detail = document.getElementById("syncProgressDetail");
      var serverEl = document.getElementById("syncServerType");
      var startBtn = document.getElementById("syncStartBtn");
      var libWrap = document.getElementById("syncLibrariesWrap");
      var libList = document.getElementById("syncLibrariesList");

      function setLibButtonsDisabled(disabled) {
        var btns = document.querySelectorAll(".sync-lib-btn");
        for (var j = 0; j < btns.length; j++) {
          btns[j].disabled = !!disabled;
        }
      }

      function escapeHtml(s) {
        if (s == null) return "";
        return String(s)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function fetchLabel(fs) {
        if (fs === "skipped") return "skipped";
        if (fs === "loading") return "fetching…";
        if (fs === "done") return "listed";
        return "pending";
      }

      function cacheLabel(cs, cached, total) {
        if (cs === "skipped") return "skipped";
        if (cs === "pending" && total === 0) return "—";
        if (cs === "pending") return "waiting (" + cached + " / " + total + ")";
        if (cs === "running") return "caching " + cached + " / " + total;
        if (cs === "done") return "done " + cached + " / " + total;
        return String(cs || "");
      }

      function renderLibraries(rows) {
        if (!rows || !rows.length) {
          libWrap.classList.add("d-none");
          libList.innerHTML = "";
          return;
        }
        libWrap.classList.remove("d-none");
        var html = "";
        for (var i = 0; i < rows.length; i++) {
          var r = rows[i];
          var name = escapeHtml(r.name);
          var itemsFound = r.itemsFound != null ? r.itemsFound : 0;
          var ct = r.cacheTotal != null ? r.cacheTotal : 0;
          var cc = r.itemsCached != null ? r.itemsCached : 0;
          var fetchL = fetchLabel(r.fetchStatus);
          var cacheL = cacheLabel(r.cacheStatus, cc, ct);
          var pct =
            ct > 0 ? Math.min(100, Math.round((cc / ct) * 100)) : r.cacheStatus === "done" ? 100 : 0;
          html +=
            '<div class="mb-3 pb-2 border-bottom border-light">' +
            '<div class="d-flex justify-content-between align-items-baseline flex-wrap">' +
            '<strong class="mr-2">' +
            name +
            "</strong>" +
            '<span class="text-muted">' +
            escapeHtml(fetchL) +
            " · " +
            itemsFound +
            " from server</span></div>" +
            '<div class="text-muted mb-1">' +
            escapeHtml(cacheL) +
            "</div>" +
            '<div class="progress" style="height: 8px;"><div class="progress-bar bg-info" role="progressbar" style="width: ' +
            pct +
            '%;"></div></div></div>';
        }
        libList.innerHTML = html;
      }

      function setBarMode(mode) {
        bar.classList.remove("bg-primary", "bg-success", "bg-danger", "progress-bar-striped", "progress-bar-animated");
        if (mode === "ok") bar.classList.add("bg-success");
        else if (mode === "err") bar.classList.add("bg-danger");
        else bar.classList.add("bg-primary");
      }

      function poll() {
        fetch(progressUrl, { credentials: "same-origin" })
          .then(function (r) {
            if (r.status === 401) {
              detail.textContent = "Session expired — refresh and sign in again.";
              return null;
            }
            return r.json();
          })
          .then(function (data) {
            if (!data) return;
            if (data.serverKind) {
              serverEl.textContent = data.serverKind;
            }
            if (data.status === "idle") {
              bar.style.width = "0%";
              bar.classList.remove("progress-bar-striped", "progress-bar-animated");
              setBarMode("primary");
              detail.textContent = "Idle — use the button below to start a sync.";
              renderLibraries([]);
              startBtn.disabled = false;
              setLibButtonsDisabled(false);
              setTimeout(poll, pollMs * 2);
              return;
            }
            startBtn.disabled = data.status === "running";
            setLibButtonsDisabled(data.status === "running");

            if (data.indeterminate) {
              bar.style.width = "100%";
              bar.classList.add("progress-bar-striped", "progress-bar-animated");
              setBarMode("primary");
              var indLab =
                data.syncScope === "single" && data.syncSingleLibrary
                  ? "Library: " + data.syncSingleLibrary + " — "
                  : "";
              detail.textContent =
                indLab + (data.label || "Working…");
              renderLibraries(data.libraries || []);
              setTimeout(poll, pollMs);
              return;
            }

            var pct = data.percent != null ? data.percent : 0;
            bar.style.width = pct + "%";
            if (data.status === "running") {
              bar.classList.add("progress-bar-striped", "progress-bar-animated");
              setBarMode("primary");
            } else {
              bar.classList.remove("progress-bar-striped", "progress-bar-animated");
            }

            if (data.status === "error") {
              setBarMode("err");
              bar.style.width = "100%";
              detail.textContent = "Error: " + (data.error || "Unknown error");
              renderLibraries(data.libraries || []);
            } else if (data.status === "done") {
              setBarMode("ok");
              bar.style.width = "100%";
              detail.textContent =
                (data.label || "Complete.") +
                (data.total > 0 ? " — " + data.total + " title(s) total." : "");
              renderLibraries(data.libraries || []);
            } else {
              var scope =
                data.syncScope === "single" && data.syncSingleLibrary
                  ? "Library: " + data.syncSingleLibrary + " — "
                  : "";
              var line =
                scope +
                (data.label || "") +
                (data.total > 0
                  ? " — " + data.processed + " / " + data.total + " (" + pct + "% overall)"
                  : data.percent != null
                  ? " — " + pct + "% overall"
                  : "");
              detail.textContent = line || "Running…";
              renderLibraries(data.libraries || []);
            }

            setTimeout(poll, pollMs);
          })
          .catch(function () {
            setTimeout(poll, pollMs * 3);
          });
      }

      setTimeout(poll, 300);
    })();
  </script>
</body>
</html>
